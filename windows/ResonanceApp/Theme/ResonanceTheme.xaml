<!-- ==========================================================================
     Resonance UX - Theme Resource Dictionary
     Complete design tokens: colors, typography, control styles, glass morphism,
     animation storyboards, spacing, and elevation for light and Deep Rest modes.
     ========================================================================== -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         COLOR PALETTE — Light Mode
         ==================================================================== -->
    <Color x:Key="ResonanceLightBase">#FAFAF8</Color>
    <Color x:Key="ResonanceLightSurface">#FFFFFF</Color>
    <Color x:Key="ResonanceGreen900">#0A1C14</Color>
    <Color x:Key="ResonanceGreen800">#122E21</Color>
    <Color x:Key="ResonanceGreen700">#1A4030</Color>
    <Color x:Key="ResonanceGreen600">#2A5A44</Color>
    <Color x:Key="ResonanceGreen500">#3D7A5E</Color>
    <Color x:Key="ResonanceGreen400">#5A9A7A</Color>
    <Color x:Key="ResonanceGreen300">#80B898</Color>
    <Color x:Key="ResonanceGreen200">#A8D4B8</Color>
    <Color x:Key="ResonanceGreen100">#D4EDE0</Color>
    <Color x:Key="ResonanceGreen50">#EDF7F1</Color>
    <Color x:Key="ResonanceGold">#C5A059</Color>
    <Color x:Key="ResonanceGoldLight">#D4B87A</Color>
    <Color x:Key="ResonanceGoldDark">#A6853E</Color>
    <Color x:Key="ResonanceTextMuted">#5C7065</Color>
    <Color x:Key="ResonanceTextSubtle">#8A9E92</Color>
    <Color x:Key="ResonanceBorderLight">#E8E8E4</Color>
    <Color x:Key="ResonanceBorderSubtle">#F0F0EC</Color>

    <!-- ====================================================================
         COLOR PALETTE — Deep Rest (Dark Mode)
         ==================================================================== -->
    <Color x:Key="ResonanceDeepRestBase">#05100B</Color>
    <Color x:Key="ResonanceDeepRestSurface">#0A1C14</Color>
    <Color x:Key="ResonanceDeepRestElevated">#122E21</Color>
    <Color x:Key="ResonanceDeepRestText">#FAFAF8</Color>
    <Color x:Key="ResonanceDeepRestTextMuted">#8A9E92</Color>
    <Color x:Key="ResonanceDeepRestBorder">#1A3528</Color>

    <!-- ====================================================================
         SOLID COLOR BRUSHES — Light
         ==================================================================== -->
    <SolidColorBrush x:Key="ResonanceBaseBrush" Color="{StaticResource ResonanceLightBase}" />
    <SolidColorBrush x:Key="ResonanceSurfaceBrush" Color="{StaticResource ResonanceLightSurface}" />
    <SolidColorBrush x:Key="ResonancePrimaryBrush" Color="{StaticResource ResonanceGreen900}" />
    <SolidColorBrush x:Key="ResonanceSecondaryBrush" Color="{StaticResource ResonanceGreen800}" />
    <SolidColorBrush x:Key="ResonanceAccentBrush" Color="{StaticResource ResonanceGold}" />
    <SolidColorBrush x:Key="ResonanceAccentLightBrush" Color="{StaticResource ResonanceGoldLight}" />
    <SolidColorBrush x:Key="ResonanceMutedTextBrush" Color="{StaticResource ResonanceTextMuted}" />
    <SolidColorBrush x:Key="ResonanceSubtleTextBrush" Color="{StaticResource ResonanceTextSubtle}" />
    <SolidColorBrush x:Key="ResonanceBorderBrush" Color="{StaticResource ResonanceBorderLight}" />

    <!-- ====================================================================
         ACRYLIC / GLASS MORPHISM BRUSHES
         ==================================================================== -->
    <AcrylicBrush x:Key="ResonanceGlassBrush"
        TintColor="{StaticResource ResonanceLightSurface}"
        TintOpacity="0.82"
        FallbackColor="{StaticResource ResonanceLightSurface}" />

    <AcrylicBrush x:Key="ResonanceGlassBrushDark"
        TintColor="{StaticResource ResonanceDeepRestSurface}"
        TintOpacity="0.75"
        FallbackColor="{StaticResource ResonanceDeepRestSurface}" />

    <AcrylicBrush x:Key="ResonanceNavigationBrush"
        TintColor="{StaticResource ResonanceLightBase}"
        TintOpacity="0.88"
        FallbackColor="{StaticResource ResonanceLightBase}" />

    <AcrylicBrush x:Key="ResonanceCardBrush"
        TintColor="#FFFFFF"
        TintOpacity="0.78"
        FallbackColor="#FFFFFF" />

    <AcrylicBrush x:Key="ResonanceCardBrushDark"
        TintColor="{StaticResource ResonanceDeepRestElevated}"
        TintOpacity="0.70"
        FallbackColor="{StaticResource ResonanceDeepRestElevated}" />

    <!-- ====================================================================
         SPACING TOKENS
         ==================================================================== -->
    <x:Double x:Key="ResonanceSpaceXS">4</x:Double>
    <x:Double x:Key="ResonanceSpaceSM">8</x:Double>
    <x:Double x:Key="ResonanceSpaceMD">16</x:Double>
    <x:Double x:Key="ResonanceSpaceLG">24</x:Double>
    <x:Double x:Key="ResonanceSpaceXL">32</x:Double>
    <x:Double x:Key="ResonanceSpaceXXL">48</x:Double>
    <x:Double x:Key="ResonanceSpaceHuge">64</x:Double>

    <Thickness x:Key="ResonancePagePadding">32,24,32,24</Thickness>
    <Thickness x:Key="ResonanceCardPadding">20,16,20,16</Thickness>
    <Thickness x:Key="ResonanceCardMargin">0,0,0,12</Thickness>
    <Thickness x:Key="ResonanceElementSpacing">0,8,0,0</Thickness>

    <!-- ====================================================================
         CORNER RADIUS TOKENS
         ==================================================================== -->
    <CornerRadius x:Key="ResonanceRadiusSM">6</CornerRadius>
    <CornerRadius x:Key="ResonanceRadiusMD">10</CornerRadius>
    <CornerRadius x:Key="ResonanceRadiusLG">16</CornerRadius>
    <CornerRadius x:Key="ResonanceRadiusXL">24</CornerRadius>
    <CornerRadius x:Key="ResonanceRadiusFull">999</CornerRadius>

    <!-- ====================================================================
         ELEVATION / SHADOW
         ==================================================================== -->
    <x:Double x:Key="ResonanceElevation0">0</x:Double>
    <x:Double x:Key="ResonanceElevation1">2</x:Double>
    <x:Double x:Key="ResonanceElevation2">8</x:Double>
    <x:Double x:Key="ResonanceElevation3">16</x:Double>
    <x:Double x:Key="ResonanceElevation4">32</x:Double>

    <!-- ====================================================================
         TYPOGRAPHY — Cormorant Garamond (Display/Heading) + Manrope (Body/UI)
         ==================================================================== -->

    <!-- Display styles: elegant, spacious, for headlines -->
    <Style x:Key="ResonanceDisplayLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cormorant Garamond" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="LineHeight" Value="56" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="ResonanceDisplayMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cormorant Garamond" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="LineHeight" Value="44" />
        <Setter Property="CharacterSpacing" Value="-10" />
    </Style>

    <Style x:Key="ResonanceDisplaySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cormorant Garamond" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="LineHeight" Value="36" />
    </Style>

    <!-- Heading styles -->
    <Style x:Key="ResonanceHeadingLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="28" />
    </Style>

    <Style x:Key="ResonanceHeadingMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <Style x:Key="ResonanceHeadingSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <!-- Body styles -->
    <Style x:Key="ResonanceBodyLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="ResonanceBodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="ResonanceBodySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
    </Style>

    <!-- Label / Caption -->
    <Style x:Key="ResonanceLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style x:Key="ResonanceCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Prose style for the Writer -->
    <Style x:Key="ResonanceProse" TargetType="RichEditBox">
        <Setter Property="FontFamily" Value="Cormorant Garamond" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MaxWidth" Value="720" />
        <Setter Property="SelectionHighlightColor" Value="{StaticResource ResonanceAccentBrush}" />
    </Style>

    <!-- ====================================================================
         BUTTON STYLES
         ==================================================================== -->

    <!-- Primary Button: Gold accent, calm presence -->
    <Style x:Key="ResonancePrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ResonanceAccentBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
        <Setter Property="Padding" Value="16,8,16,8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Secondary Button: Subtle, outlined -->
    <Style x:Key="ResonanceSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ResonancePrimaryBrush}" />
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
        <Setter Property="Padding" Value="16,8,16,8" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Ghost Button: Minimal, for toolbar actions -->
    <Style x:Key="ResonanceGhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceMutedTextBrush}" />
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
        <Setter Property="Padding" Value="8,6,8,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- Icon Button: Square, for toolbar icons -->
    <Style x:Key="ResonanceIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ====================================================================
         TEXTBOX STYLES
         ==================================================================== -->

    <Style x:Key="ResonanceTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
        <Setter Property="Padding" Value="12,8,12,8" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource ResonanceSurfaceBrush}" />
    </Style>

    <Style x:Key="ResonanceSearchBox" TargetType="AutoSuggestBox">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusSM}" />
    </Style>

    <!-- ====================================================================
         CARD STYLE
         ==================================================================== -->

    <Style x:Key="ResonanceCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResonanceCardBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusMD}" />
        <Setter Property="Padding" Value="{StaticResource ResonanceCardPadding}" />
    </Style>

    <Style x:Key="ResonanceCardDark" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResonanceCardBrushDark}" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceRadiusMD}" />
        <Setter Property="Padding" Value="{StaticResource ResonanceCardPadding}" />
    </Style>

    <!-- ====================================================================
         NAVIGATION VIEW STYLE
         ==================================================================== -->

    <Style x:Key="ResonanceNavigationView" TargetType="NavigationView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="IsBackButtonVisible" Value="Collapsed" />
        <Setter Property="OpenPaneLength" Value="240" />
        <Setter Property="CompactPaneLength" Value="56" />
        <Setter Property="IsPaneToggleButtonVisible" Value="False" />
    </Style>

    <!-- ====================================================================
         ANIMATION STORYBOARD RESOURCES
         ==================================================================== -->

    <!-- Gentle fade in: 500ms ease-out -->
    <Storyboard x:Key="ResonanceFadeIn">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.5">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Gentle fade out: 300ms ease-in -->
    <Storyboard x:Key="ResonanceFadeOut">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1" To="0"
            Duration="0:0:0.3">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseIn" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Slide up entrance: 400ms -->
    <Storyboard x:Key="ResonanceSlideUp">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            From="16" To="0"
            Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Hover lift: subtle upward movement -->
    <Storyboard x:Key="ResonanceHoverLift">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            To="-2"
            Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Hover release: return to rest -->
    <Storyboard x:Key="ResonanceHoverRelease">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            To="0"
            Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Gold pulse: subtle attention draw for important state changes -->
    <Storyboard x:Key="ResonanceGoldPulse" RepeatBehavior="1x">
        <ColorAnimation
            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
            From="#00C5A059" To="#40C5A059"
            Duration="0:0:0.4"
            AutoReverse="True">
            <ColorAnimation.EasingFunction>
                <CubicEase EasingMode="EaseInOut" />
            </ColorAnimation.EasingFunction>
        </ColorAnimation>
    </Storyboard>

    <!-- Phase transition: slow crossfade for theme changes -->
    <Storyboard x:Key="ResonancePhaseTransition">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1" To="0"
            Duration="0:0:0.8">
            <DoubleAnimation.EasingFunction>
                <QuarticEase EasingMode="EaseInOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- ====================================================================
         ANIMATION DURATIONS
         ==================================================================== -->
    <Duration x:Key="ResonanceDurationFast">0:0:0.15</Duration>
    <Duration x:Key="ResonanceDurationNormal">0:0:0.3</Duration>
    <Duration x:Key="ResonanceDurationSlow">0:0:0.5</Duration>
    <Duration x:Key="ResonanceDurationCalm">0:0:0.8</Duration>

</ResourceDictionary>
