const { useState, useEffect, useRef } = React;

// ============================================================
// RSD CHECK-IN - "Am I Overreacting?" Real-Time Support Chat
// Polyvagal-informed. Grounding techniques. Reframing tools.
// ============================================================

const SCENARIOS = [
  {
    id: 'work-email',
    title: 'Got a vague email from my boss',
    category: 'Work',
    icon: '💼',
    commonThoughts: [
      "They're going to fire me",
      "I did something wrong",
      "Everyone noticed my mistake",
      "I'm about to be criticized"
    ],
    reframe: "A vague email usually means exactly what it says — they need to discuss something. Your RSD is filling in the blanks with worst-case scenarios.",
    grounding: "Before you respond or spiral: What evidence do you actually have? Has your boss ever fired someone via vague email? Probably not."
  },
  {
    id: 'friend-cancel',
    title: 'Friend cancelled plans',
    category: 'Relationships',
    icon: '👥',
    commonThoughts: [
      "They don't actually want to see me",
      "I'm not a priority to them",
      "They're probably with someone else",
      "Our friendship is fading"
    ],
    reframe: "People cancel plans for countless reasons — exhaustion, anxiety, emergencies, needing alone time. It's almost never about you.",
    grounding: "Think about the last 5 interactions with this person. Were they warm? Engaged? That's the real pattern, not this one cancellation."
  },
  {
    id: 'no-reply',
    title: 'Someone didn\'t text back',
    category: 'Relationships',
    icon: '📱',
    commonThoughts: [
      "They're ignoring me on purpose",
      "I said something wrong",
      "They don't care about me",
      "I'm being ghosted"
    ],
    reframe: "People are busy, distracted, overwhelmed by their own lives. A delayed reply is rarely personal.",
    grounding: "How often do YOU forget to reply to messages? Probably more than you realize. Extend that same grace."
  },
  {
    id: 'social-awkward',
    title: 'Said something awkward in a group',
    category: 'Social',
    icon: '🗣',
    commonThoughts: [
      "Everyone noticed and judged me",
      "They think I'm weird",
      "I ruined the conversation",
      "They're talking about me now"
    ],
    reframe: "The spotlight effect is real — you notice your own awkward moments 10x more than anyone else does. They've already forgotten.",
    grounding: "Can you remember the last awkward thing someone else said? Probably not. That's how much others remember yours."
  },
  {
    id: 'feedback',
    title: 'Received constructive criticism',
    category: 'Work',
    icon: '📋',
    commonThoughts: [
      "They think I'm incompetent",
      "I should have known better",
      "I'm going to lose this job",
