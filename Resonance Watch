// --- MAIN COMPONENT ---
const ResonanceWatch = () => {
  const [currentScreen, setCurrentScreen] = useState(0);
  const [animKey, setAnimKey] = useState(0);

  const goTo = useCallback((idx) => {
    if (idx < 0 || idx >= SCREENS.length || idx === currentScreen) return;
    setCurrentScreen(idx);
    setAnimKey(k => k + 1);
  }, [currentScreen]);

  const ActiveScreen = SCREENS[currentScreen].component;

  return (
    <div style={{
      minHeight: '100vh',
      background: '#0D0D0D',
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      justifyContent: 'center',
      fontFamily: T.sans,
      gap: 20,
    }}>
      <WatchStyles />

      {/* Title */}
      <div style={{ fontFamily: T.serif, fontSize: 18, color: T.textMuted, letterSpacing: 3, textTransform: 'uppercase' }}>
        Resonance Watch
      </div>

      {/* Watch body */}
      <div style={{ position: 'relative' }}>
        {/* Watch frame */}
        <div style={{
          width: 198,
          height: 242,
          borderRadius: 48,
          border: '8px solid #1a1a1a',
          background: T.bgBase,
          overflow: 'hidden',
          position: 'relative',
          boxShadow: '0 8px 40px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05)',
        }}>
          {/* Screen content */}
          <div
            key={animKey}
            className="watch-screen-enter"
            style={{ width: '100%', height: '100%' }}
          >
            <ActiveScreen />
          </div>
        </div>

        {/* Digital crown */}
        <div style={{
          position: 'absolute',
          right: -14,
          top: '38%',
          width: 6,
          height: 24,
          borderRadius: 3,
          background: '#2a2a2a',
          border: '1px solid #333',
          boxShadow: '1px 0 4px rgba(0,0,0,0.4)',
        }} />
        {/* Side button */}
        <div style={{
          position: 'absolute',
          right: -12,
          top: '56%',
          width: 4,
          height: 14,
          borderRadius: 2,
          background: '#252525',
          border: '1px solid #333',
        }} />
      </div>

      {/* Dot navigation */}
      <div style={{ display: 'flex', gap: 6, alignItems: 'center' }}>
        {SCREENS.map((s, i) => (
          <button
            key={s.id}
            onClick={() => goTo(i)}
            style={{
              width: i === currentScreen ? 14 : 6,
              height: 6,
              borderRadius: 3,
              border: 'none',
              background: i === currentScreen ? T.gold : T.textDim,
              cursor: 'pointer',
              transition: 'all 0.3s ease',
              padding: 0,
            }}
          />
        ))}
      </div>

      {/* Swipe buttons */}
      <div style={{ display: 'flex', gap: 12 }}>
        <button
          onClick={() => goTo(currentScreen - 1)}
          disabled={currentScreen === 0}
          style={{
            fontFamily: T.sans,
            fontSize: 10,
            color: currentScreen === 0 ? T.textDim : T.textMuted,
            background: 'transparent',
            border: `1px solid ${currentScreen === 0 ? '#222' : T.borderLight}`,
            borderRadius: 8,
            padding: '5px 14px',
            cursor: currentScreen === 0 ? 'default' : 'pointer',
            transition: 'all 0.2s',
          }}
        >
          &larr; Prev
        </button>
        <button
          onClick={() => goTo(currentScreen + 1)}
          disabled={currentScreen === SCREENS.length - 1}
          style={{
            fontFamily: T.sans,
            fontSize: 10,
            color: currentScreen === SCREENS.length - 1 ? T.textDim : T.textMuted,
            background: 'transparent',
            border: `1px solid ${currentScreen === SCREENS.length - 1 ? '#222' : T.borderLight}`,
            borderRadius: 8,
            padding: '5px 14px',
            cursor: currentScreen === SCREENS.length - 1 ? 'default' : 'pointer',
            transition: 'all 0.2s',
          }}
        >
          Next &rarr;
        </button>
      </div>

      {/* Screen label */}
      <div style={{ fontFamily: T.sans, fontSize: 9, color: T.textDim, letterSpacing: 1 }}>
        {currentScreen + 1} / {SCREENS.length} &middot; {SCREENS[currentScreen].id.toUpperCase()}
      </div>
    </div>
  );
};

