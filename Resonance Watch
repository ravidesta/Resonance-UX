// --- SCREEN 4: BREATHING EXERCISE ---
const BreathingExercise = () => {
  const [active, setActive] = useState(false);
  const [phase, setPhase] = useState('inhale');
  const [elapsed, setElapsed] = useState(0);
  const cycleDuration = 8000; // 4s in, 4s out
  const totalDuration = 60;

  useEffect(() => {
    if (!active) return;
    const start = Date.now();
    const id = setInterval(() => {
      const now = Date.now();
      const diff = now - start;
      const secs = Math.floor(diff / 1000);
      setElapsed(secs);
      const cyclePos = diff % cycleDuration;
      setPhase(cyclePos < cycleDuration / 2 ? 'inhale' : 'exhale');
      if (secs >= totalDuration) {
        setActive(false);
        setElapsed(0);
        clearInterval(id);
      }
    }, 100);
    return () => clearInterval(id);
  }, [active]);

  return (
    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', height: '100%', gap: 8 }}>
      <div style={{ fontFamily: T.sans, fontSize: 10, color: T.textMuted, fontWeight: 500 }}>
        Breathe
      </div>
      <div
        onClick={() => !active && setActive(true)}
        style={{
          width: 72,
          height: 72,
          borderRadius: '50%',
          background: `radial-gradient(circle, ${T.green600} 0%, ${T.bgCard} 100%)`,
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          cursor: active ? 'default' : 'pointer',
          animation: active ? `breatheCircle ${cycleDuration}ms ease-in-out infinite` : 'none',
          transition: 'transform 0.3s',
          boxShadow: active ? `0 0 24px ${T.green600}` : 'none',
        }}
      >
        <div style={{
          width: 28,
          height: 28,
          borderRadius: '50%',
          background: T.gold,
          opacity: 0.6,
        }} />
      </div>
      <div style={{ fontFamily: T.serif, fontSize: 14, color: T.textMain, fontStyle: 'italic' }}>
        {active ? phase : 'Tap to begin'}
      </div>
      {active && (
        <div style={{ fontFamily: T.sans, fontSize: 8, color: T.textDim }}>
          {totalDuration - elapsed}s remaining
        </div>
      )}
    </div>
  );
};

