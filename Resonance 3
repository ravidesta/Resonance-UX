            ) : (
              /* Soft empty state for spaciousness */
              <div className="border border-dashed border-[var(--border-light)] rounded-[16px] p-4 flex items-center justify-center opacity-50">
                <span className="text-xs font-serif italic text-[var(--text-light)]">Unstructured flow</span>
              </div>
            )}
          </div>
        ))}
      </main>
    </div>
  );
}

function FocusView({ tasks, onToggle }) {
  const activeTasks = tasks.filter(t => !t.completed);
  const completedTasks = tasks.filter(t => t.completed);

  return (
    <div className="flex-1 flex flex-col relative z-10 animate-in fade-in duration-700 h-full">
      <header className="px-6 pt-14 pb-4">
        <span className="text-[10px] font-semibold text-[var(--gold-dark)] uppercase tracking-[0.2em] block mb-1">
          Present Focus
        </span>
        <h1 className="font-serif text-4xl font-semibold text-[var(--text-main)] leading-none mb-4">
          Cultivation
        </h1>
      </header>

      <main className="flex-1 overflow-y-auto px-6 hide-scrollbar pb-32">
        <div className="space-y-3 mt-4">
          {activeTasks.map(task => (
            <TaskCard key={task.id} task={task} onToggle={() => onToggle(task.id)} />
          ))}
        </div>

        {completedTasks.length > 0 && (
          <div className="mt-8 mb-4 flex items-center gap-4">
            <div className="flex-1 h-px bg-[var(--border-light)]"></div>
            <span className="text-[10px] font-semibold text-[var(--text-light)] uppercase tracking-widest">Completed</span>
            <div className="flex-1 h-px bg-[var(--border-light)]"></div>
          </div>
        )}

        <div className="space-y-3 opacity-60">
          {completedTasks.map(task => (
            <TaskCard key={task.id} task={task} onToggle={() => onToggle(task.id)} />
          ))}
        </div>
      </main>
    </div>
  );
}

