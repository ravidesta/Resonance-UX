            {/* The flowing timeline line */}
            {index !== rhythms.length - 1 && <div className="rhythm-line"></div>}
            
            {/* Phase Node */}
            <div className="absolute left-0 top-1 w-6 h-6 rounded-full bg-[var(--bg-surface)] border border-[var(--border-light)] flex items-center justify-center">
              <div className={`w-2 h-2 rounded-full ${phase.isActive ? 'bg-[var(--gold-primary)] shadow-[0_0_10px_var(--gold-primary)]' : 'bg-[var(--border-light)]'}`}></div>
