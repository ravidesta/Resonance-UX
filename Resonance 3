// --- COMPONENTS ---

function TaskCard({ task, onToggle }) {
  const getEnergyConfig = (energy) => {
    switch(energy) {
      case 'high': return { icon: <Sun size={12}/>, color: '#D87050', label: 'Deep Work' };
      case 'balanced': return { icon: <Leaf size={12}/>, color: '#9A7A3A', label: 'Flow State' };
      case 'low': return { icon: <Moon size={12}/>, color: '#5C7065', label: 'Light Duty' };
      case 'restorative': return { icon: <Wind size={12}/>, color: '#8A9C91', label: 'Restorative' };
      default: return { icon: <Leaf size={12}/>, color: '#9A7A3A', label: 'Flow' };
    }
  };

  const config = getEnergyConfig(task.energy);

  return (
    <div className={`task-row group bg-[var(--bg-surface)] border border-[var(--border-light)] rounded-[20px] p-4 flex gap-4 items-start shadow-sm transition-all hover:border-[var(--border-focus)] ${task.completed ? 'opacity-70' : ''}`}>
      
      <button 
        onClick={onToggle}
        className={`task-check mt-0.5 flex-shrink-0 ${task.completed ? 'text-[var(--gold-primary)] completed' : 'text-[var(--border-light)]'}`}
      >
        {task.completed ? <CheckCircle2 size={24} strokeWidth={1.5} fill="var(--bg-surface)" /> : <Circle size={24} strokeWidth={1.5} />}
      </button>

      <div className="flex-1 min-w-0">
        <h3 className={`font-serif text-lg leading-tight mb-2 transition-colors ${task.completed ? 'text-[var(--text-light)] line-through decoration-[var(--border-light)]' : 'text-[var(--text-main)]'}`}>
          {task.title}
        </h3>
        
        <div className="flex items-center gap-3 flex-wrap">
          <span 
            className="inline-flex items-center gap-1 text-[10px] font-semibold uppercase tracking-widest px-2 py-1 rounded-md bg-[var(--bg-base)] border border-[var(--border-light)]"
            style={{ color: task.completed ? 'var(--text-light)' : config.color }}
          >
            {config.icon} {config.label}
          </span>
          
          <span className="text-[10px] font-sans text-[var(--text-light)] uppercase tracking-wider">
            {task.domain}
          </span>

          {task.collaborator && !task.completed && (
            <span className="text-[10px] font-serif italic text-[var(--gold-primary)] ml-auto flex items-center gap-1">
              <User size={10} /> Shared with {task.collaborator}
            </span>
          )}
        </div>
      </div>
    </div>
  );
}

function EnergyBtn({ icon, label, active, onClick, type }) {
  // Using simplified visual states that work across both light and deep modes
  return (
    <button 
      onClick={onClick}
      className={`flex-1 flex flex-col items-center gap-1 py-3 px-2 rounded-xl border transition-all ${
        active 
        ? 'bg-[var(--bg-base)] text-[var(--gold-primary)] border-[var(--gold-primary)]' 
        : 'bg-transparent text-[var(--text-light)] border-[var(--border-light)] hover:border-[var(--gold-dark)]'
      }`}
    >
      {icon}
      <span className="text-[9px] font-semibold uppercase tracking-widest">{label}</span>
    </button>
  );
}

function NavItem({ icon, label, active, onClick }) {
  return (
    <button onClick={onClick} className={`flex flex-col items-center gap-1 w-14 transition-colors ${active ? 'text-[var(--gold-dark)]' : 'text-[var(--text-light)] hover:text-[var(--text-main)]'}`}>
      {React.cloneElement(icon, { size: 22, strokeWidth: active ? 2 : 1.5 })}
      <span className="text-[9px] font-semibold tracking-wider uppercase mt-1">{label}</span>
    </button>
  );
}
