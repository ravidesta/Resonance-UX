// --- MAIN APP COMPONENT ---
export default function App() {
  const [view, setView] = useState('rhythms'); // 'focus', 'domains', 'rhythms'
  const [tasks, setTasks] = useState(initialTasks);
  const [isAdding, setIsAdding] = useState(false);
  const [isDeepMode, setIsDeepMode] = useState(false); // Dark Mode toggle

  const toggleTask = (id) => {
    setTasks(tasks.map(t => t.id === id ? { ...t, completed: !t.completed } : t));
  };

  return (
    <div className={`min-h-screen flex items-center justify-center p-4 font-sans transition-colors duration-1000 ${isDeepMode ? 'bg-[#05100B] theme-deep' : 'bg-[#E5EBE7]'}`}>
      <CustomStyles />
      
      {/* Mobile Device Simulator */}
      <div className="relative w-full max-w-[400px] h-[850px] max-h-[90vh] bg-[var(--bg-base)] rounded-[40px] shadow-2xl overflow-hidden border-[8px] border-[var(--bg-surface)] flex flex-col transition-colors duration-1000">
        
        <div className="blob-1 organic-blob"></div>
        <div className="blob-2 organic-blob"></div>
        <div className="paper-noise"></div>

        {/* Global Header Actions (Deep Rest Toggle) */}
        <div className="absolute top-6 right-6 z-50">
          <button 
            onClick={() => setIsDeepMode(!isDeepMode)}
            className="w-10 h-10 rounded-full bg-[var(--bg-surface)] border border-[var(--border-light)] text-[var(--gold-primary)] flex items-center justify-center shadow-sm hover:scale-105 transition-all"
            title="Toggle Deep Rest Mode"
          >
            {isDeepMode ? <Sun size={18} strokeWidth={1.5} /> : <Moon size={18} strokeWidth={1.5} />}
          </button>
        </div>

        {/* Dynamic Views */}
        {view === 'focus' && <FocusView tasks={tasks} onToggle={toggleTask} />}
        {view === 'domains' && <DomainsView domains={domains} />}
        {view === 'rhythms' && <RhythmsView rhythms={dailyRhythms} />}

        {/* Drawer overlay for adding tasks */}
        {isAdding && <CreateDrawer onClose={() => setIsAdding(false)} />}

        {/* Bottom Navigation */}
        <nav className="absolute bottom-0 w-full glass-panel z-40 px-6 py-5 pb-8 flex justify-between items-center rounded-t-[30px] transition-colors duration-1000">
          <NavItem 
            icon={<Clock />} 
            label="Rhythms" 
            active={view === 'rhythms'} 
            onClick={() => setView('rhythms')} 
          />
          <NavItem 
            icon={<Sprout />} 
            label="Focus" 
            active={view === 'focus'} 
            onClick={() => setView('focus')} 
          />
          
          {/* Gentle Create Action */}
          <button 
            onClick={() => setIsAdding(true)}
            className="w-12 h-12 bg-[var(--text-main)] rounded-full flex items-center justify-center text-[var(--bg-base)] shadow-lg transform -translate-y-4 hover:bg-[var(--gold-dark)] transition-all hover:scale-105"
          >
            <Plus size={22} strokeWidth={1.5} />
          </button>
          
          <NavItem 
            icon={<Briefcase />} 
            label="Domains" 
            active={view === 'domains'} 
            onClick={() => setView('domains')} 
          />
        </nav>
      </div>
    </div>
  );
}

