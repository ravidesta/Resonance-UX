<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="LuminousCosmic.Views.OnboardingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    PrimaryButtonText="Calculate My Chart"
    CloseButtonText="Explore Demo"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    CornerRadius="{StaticResource ResonanceCornerXLarge}">

    <ContentDialog.TitleTemplate>
        <DataTemplate>
            <StackPanel Spacing="4" Margin="0,8,0,0">
                <TextBlock Text="&#x2726; LUMINOUS COSMIC ARCHITECTURE"
                           Style="{StaticResource ResonanceAccentLabelStyle}" />
                <TextBlock Text="Welcome, Cosmic Explorer"
                           Style="{StaticResource ResonanceTitleStyle}" />
            </StackPanel>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <StackPanel Spacing="20" MinWidth="420">

        <TextBlock Style="{StaticResource ResonanceBodyStyle}">
            To generate your personal cosmic blueprint, enter your birth details below.
            This information is used to calculate your natal chart and is stored only on your device.
        </TextBlock>

        <Rectangle Height="1" Fill="{StaticResource ResonanceGoldBorderBrush}" />

        <!-- Name -->
        <StackPanel Spacing="6">
            <TextBlock Text="Name"
                       Style="{StaticResource ResonanceCaptionStyle}"
                       FontWeight="SemiBold" />
            <TextBox x:Name="NameInput"
                     Style="{StaticResource ResonanceTextBoxStyle}"
                     PlaceholderText="Your name or preferred alias" />
        </StackPanel>

        <!-- Birth Date -->
        <StackPanel Spacing="6">
            <TextBlock Text="Birth Date"
                       Style="{StaticResource ResonanceCaptionStyle}"
                       FontWeight="SemiBold" />
            <CalendarDatePicker x:Name="BirthDatePicker"
                                PlaceholderText="Select your birth date"
                                HorizontalAlignment="Stretch"
                                CornerRadius="{StaticResource ResonanceCornerMedium}" />
        </StackPanel>

        <!-- Birth Time -->
        <StackPanel Spacing="6">
            <TextBlock Text="Birth Time (as accurate as possible)"
                       Style="{StaticResource ResonanceCaptionStyle}"
                       FontWeight="SemiBold" />
            <TimePicker x:Name="BirthTimePicker"
                        HorizontalAlignment="Stretch"
                        CornerRadius="{StaticResource ResonanceCornerMedium}" />
        </StackPanel>

        <!-- Birth City -->
        <StackPanel Spacing="6">
            <TextBlock Text="Birth City"
                       Style="{StaticResource ResonanceCaptionStyle}"
                       FontWeight="SemiBold" />
            <TextBox x:Name="BirthCityInput"
                     Style="{StaticResource ResonanceTextBoxStyle}"
                     PlaceholderText="City, Country" />
        </StackPanel>

        <!-- Coordinates (simplified - would use geocoding API in production) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Latitude"
                           Style="{StaticResource ResonanceCaptionStyle}"
                           FontWeight="SemiBold" />
                <NumberBox x:Name="LatitudeInput"
                           Value="40.7128"
                           Minimum="-90" Maximum="90"
                           SpinButtonPlacementMode="Compact"
                           CornerRadius="{StaticResource ResonanceCornerMedium}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="Longitude"
                           Style="{StaticResource ResonanceCaptionStyle}"
                           FontWeight="SemiBold" />
                <NumberBox x:Name="LongitudeInput"
                           Value="-74.006"
                           Minimum="-180" Maximum="180"
                           SpinButtonPlacementMode="Compact"
                           CornerRadius="{StaticResource ResonanceCornerMedium}" />
            </StackPanel>

            <StackPanel Grid.Column="4" Spacing="6">
                <TextBlock Text="UTC Offset"
                           Style="{StaticResource ResonanceCaptionStyle}"
                           FontWeight="SemiBold" />
                <NumberBox x:Name="TimezoneInput"
                           Value="-5"
                           Minimum="-12" Maximum="14"
                           SpinButtonPlacementMode="Compact"
                           CornerRadius="{StaticResource ResonanceCornerMedium}" />
            </StackPanel>
        </Grid>

        <Rectangle Height="1" Fill="{StaticResource ResonanceGoldBorderBrush}" />

        <!-- Privacy note -->
        <Border Background="{StaticResource ResonanceSurfaceBrush}"
                CornerRadius="{StaticResource ResonanceCornerMedium}"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72E;" FontSize="14"
                          Foreground="{StaticResource ResonanceAccentBrush}" />
                <TextBlock Style="{StaticResource ResonanceCaptionStyle}"
                           VerticalAlignment="Center">
                    Your birth data is stored locally and never shared.
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</ContentDialog>
