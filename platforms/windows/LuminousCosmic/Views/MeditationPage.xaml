<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LuminousCosmic.Views.MeditationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="{StaticResource ResonancePagePadding}" MaxWidth="900">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                       Text="MEDITATION" />
            <TextBlock Style="{StaticResource ResonanceTitleStyle}"
                       Text="Cosmic Stillness" />
            <TextBlock Style="{StaticResource ResonanceCaptionStyle}"
                       Text="Guided meditations aligned with celestial rhythms" />
        </StackPanel>

        <!-- ══ Main Content ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">

                <!-- ── Active Session / Timer ── -->
                <Border Style="{StaticResource ResonanceDarkCardStyle}" Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Session Title -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4"
                                    Margin="0,0,0,24">
                            <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                                       HorizontalAlignment="Center"
                                       Text="CURRENT SESSION" />
                            <TextBlock x:Name="SessionTitle"
                                       FontFamily="Cambria, Georgia" FontSize="24"
                                       Foreground="{StaticResource ResonanceNavTextBrush}"
                                       HorizontalAlignment="Center"
                                       Text="Lunar Breathing" />
                        </StackPanel>

                        <!-- Timer Visual -->
                        <Grid Grid.Row="1" Width="220" Height="220"
                              HorizontalAlignment="Center" Margin="0,0,0,24">
                            <!-- Outer ring -->
                            <Ellipse Width="220" Height="220"
                                     Stroke="{StaticResource ResonanceGoldBorderBrush}"
                                     StrokeThickness="2" />
                            <!-- Progress ring -->
                            <ProgressRing x:Name="TimerRing"
                                          Width="200" Height="200"
                                          IsIndeterminate="False"
                                          Value="0"
                                          Maximum="100"
                                          Foreground="{StaticResource ResonanceAccentBrush}"
                                          Background="Transparent"
                                          IsActive="False" />
                            <!-- Timer text -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="TimerText"
                                           FontFamily="Cambria, Georgia"
                                           FontSize="42" FontWeight="Light"
                                           Foreground="{StaticResource ResonanceNavTextBrush}"
                                           HorizontalAlignment="Center"
                                           Text="10:00" />
                                <TextBlock x:Name="TimerLabel"
                                           Style="{StaticResource ResonanceCaptionStyle}"
                                           Foreground="{StaticResource ResonanceAccentBrush}"
                                           HorizontalAlignment="Center"
                                           Text="minutes" />
                            </StackPanel>
                        </Grid>

                        <!-- Guidance text -->
                        <TextBlock Grid.Row="2" x:Name="GuidanceText"
                                   Style="{StaticResource ResonanceBodyStyle}"
                                   Foreground="{StaticResource ResonanceTextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"
                                   MaxWidth="400">
                            Close your eyes. Breathe in harmony with the lunar rhythm.
                            Let each inhale draw in cosmic light, each exhale release what no longer serves.
                        </TextBlock>

                        <!-- Controls -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="16"
                                    Margin="0,0,0,16">
                            <Button x:Name="StartButton"
                                    Style="{StaticResource ResonancePrimaryButtonStyle}"
                                    Content="Begin Meditation"
                                    Click="StartMeditation_Click"
                                    Width="180" />
                            <Button x:Name="PauseButton"
                                    Style="{StaticResource ResonanceSecondaryButtonStyle}"
                                    Content="Pause"
                                    Click="PauseMeditation_Click"
                                    Visibility="Collapsed"
                                    Width="100" />
                            <Button x:Name="StopButton"
                                    Style="{StaticResource ResonanceSecondaryButtonStyle}"
                                    Content="End"
                                    Click="StopMeditation_Click"
                                    Visibility="Collapsed"
                                    Width="100" />
                        </StackPanel>

                        <!-- Duration selector -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Duration:"
                                       Style="{StaticResource ResonanceCaptionStyle}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource ResonanceTextTertiaryBrush}" />
                            <RadioButton x:Name="Duration5" Content="5 min" GroupName="Duration"
                                         Foreground="{StaticResource ResonanceNavTextBrush}"
                                         Click="DurationChanged" Tag="5" />
                            <RadioButton x:Name="Duration10" Content="10 min" GroupName="Duration"
                                         IsChecked="True"
                                         Foreground="{StaticResource ResonanceNavTextBrush}"
                                         Click="DurationChanged" Tag="10" />
                            <RadioButton x:Name="Duration20" Content="20 min" GroupName="Duration"
                                         Foreground="{StaticResource ResonanceNavTextBrush}"
                                         Click="DurationChanged" Tag="20" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Meditation Library ── -->
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource ResonanceSubtitleStyle}"
                               Text="Guided Sessions" />

                    <ItemsRepeater x:Name="MeditationList">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="280" MinItemHeight="160"
                                               MinColumnSpacing="16" MinRowSpacing="16"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ResonanceGoldCardStyle}"
                                        Padding="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Theme}"
                                                   Style="{StaticResource ResonanceAccentLabelStyle}" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="Cambria, Georgia"
                                                   FontSize="18"
                                                   Foreground="{StaticResource ResonanceTextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource ResonanceCaptionStyle}"
                                                   MaxLines="3" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12"
                                                   Foreground="{StaticResource ResonanceAccentBrush}"
                                                   Margin="0,4,0,0">
                                            <Run Text="{Binding Duration}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
