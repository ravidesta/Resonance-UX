<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LuminousCosmic.Views.NatalChartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    Background="Transparent">

    <Grid Padding="{StaticResource ResonancePagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Chart Canvas ══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                           Text="NATAL CHART" />
                <TextBlock x:Name="ChartTitleText"
                           Style="{StaticResource ResonanceTitleStyle}"
                           Text="Your Cosmic Blueprint" />
                <TextBlock x:Name="ChartSubtitleText"
                           Style="{StaticResource ResonanceCaptionStyle}"
                           Text="Born June 21, 1990 at 2:30 PM" />
            </StackPanel>

            <!-- Chart rendering area -->
            <Border Grid.Row="1"
                    Style="{StaticResource ResonanceCardStyle}"
                    Padding="0"
                    MinHeight="500">
                <canvas:CanvasControl x:Name="ChartCanvas"
                                       Draw="ChartCanvas_Draw"
                                       CreateResources="ChartCanvas_CreateResources" />
            </Border>
        </Grid>

        <!-- ══ RIGHT: Chart Details Panel ══ -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- Big Three -->
                <Border Style="{StaticResource ResonanceDarkCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                                   Text="THE BIG THREE" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x2609;" FontSize="24"
                                       Foreground="{StaticResource ResonanceAccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="SunSignText" Text="Sun in Gemini"
                                           FontFamily="Cambria, Georgia" FontSize="15"
                                           Foreground="{StaticResource ResonanceNavTextBrush}" />
                                <TextBlock x:Name="SunHouseText" Text="10th House"
                                           FontSize="12"
                                           Foreground="{StaticResource ResonanceTextTertiaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x263D;" FontSize="24"
                                       Foreground="{StaticResource ResonanceAccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="MoonSignText" Text="Moon in Scorpio"
                                           FontFamily="Cambria, Georgia" FontSize="15"
                                           Foreground="{StaticResource ResonanceNavTextBrush}" />
                                <TextBlock x:Name="MoonHouseText" Text="3rd House"
                                           FontSize="12"
                                           Foreground="{StaticResource ResonanceTextTertiaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="AC" FontSize="18"
                                       FontFamily="Cambria, Georgia" FontWeight="Bold"
                                       Foreground="{StaticResource ResonanceAccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="RisingSignText" Text="Rising in Scorpio"
                                           FontFamily="Cambria, Georgia" FontSize="15"
                                           Foreground="{StaticResource ResonanceNavTextBrush}" />
                                <TextBlock x:Name="RisingDegreeText" Text="15 deg 23 min"
                                           FontSize="12"
                                           Foreground="{StaticResource ResonanceTextTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Planetary Positions -->
                <Border Style="{StaticResource ResonanceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                                   Text="PLANETARY POSITIONS" />

                        <ItemsRepeater x:Name="PlanetPositionsList">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                                   FontSize="16"
                                                   Foreground="{StaticResource ResonanceAccentBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Planet}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource ResonanceTextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding DegreeDisplay}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ResonanceTextTertiaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Aspects -->
                <Border Style="{StaticResource ResonanceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                                   Text="MAJOR ASPECTS" />

                        <ItemsRepeater x:Name="AspectsList">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ResonanceTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding TypeSymbol}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource ResonanceAccentBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- House Cusps -->
                <Border Style="{StaticResource ResonanceGoldCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource ResonanceAccentLabelStyle}"
                                   Text="HOUSE CUSPS" />

                        <ItemsRepeater x:Name="HousesList">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ResonanceTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Sign}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ResonanceAccentBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
