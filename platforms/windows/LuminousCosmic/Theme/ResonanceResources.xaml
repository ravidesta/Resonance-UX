<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         RESONANCE UX DESIGN SYSTEM - Luminous Cosmic Architecture
         Deep forest greens, gold accents, cream base, warm shadows
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Core Forest Green Palette ── -->
    <Color x:Key="ForestDeep">#FF0A1C14</Color>
    <Color x:Key="ForestMid">#FF122E21</Color>
    <Color x:Key="ForestLight">#FF1B402E</Color>
    <Color x:Key="ForestNight">#FF05100B</Color>
    <Color x:Key="ForestMuted">#FF5C7065</Color>
    <Color x:Key="ForestSoft">#FF8A9C91</Color>

    <!-- ── Gold Accent Palette ── -->
    <Color x:Key="GoldPrimary">#FFC5A059</Color>
    <Color x:Key="GoldLight">#FFE6D0A1</Color>
    <Color x:Key="GoldDark">#FF9A7A3A</Color>
    <Color x:Key="GoldShimmer">#FFDAC07A</Color>

    <!-- ── Cream Base Palette ── -->
    <Color x:Key="CreamWhite">#FFFAFAF8</Color>
    <Color x:Key="CreamWarm">#FFF5F4EE</Color>
    <Color x:Key="CreamDark">#FFE8E6DD</Color>

    <!-- ── Zodiac Element Colors ── -->
    <Color x:Key="ElementFire">#FFB85C3A</Color>
    <Color x:Key="ElementEarth">#FF6B7D4A</Color>
    <Color x:Key="ElementAir">#FF7A9BAF</Color>
    <Color x:Key="ElementWater">#FF4A6B7D</Color>

    <!-- ── Aspect Line Colors ── -->
    <Color x:Key="AspectConjunction">#FFC5A059</Color>
    <Color x:Key="AspectSextile">#FF7A9BAF</Color>
    <Color x:Key="AspectSquare">#FFB85C3A</Color>
    <Color x:Key="AspectTrine">#FF6B7D4A</Color>
    <Color x:Key="AspectOpposition">#FF9A4A4A</Color>

    <!-- ══════════════════════════════════════════
         LIGHT THEME (Day Mode) BRUSHES
         ══════════════════════════════════════════ -->

    <!-- Background layers -->
    <SolidColorBrush x:Key="ResonanceBackgroundBrush" Color="{StaticResource CreamWhite}" />
    <SolidColorBrush x:Key="ResonanceSurfaceBrush" Color="{StaticResource CreamWarm}" />
    <SolidColorBrush x:Key="ResonanceCardBrush" Color="#FFFFFFFF" />

    <!-- Navigation -->
    <SolidColorBrush x:Key="ResonanceNavBackgroundBrush" Color="{StaticResource ForestDeep}" />
    <SolidColorBrush x:Key="ResonanceNavItemHoverBrush" Color="{StaticResource ForestMid}" />
    <SolidColorBrush x:Key="ResonanceNavItemSelectedBrush" Color="{StaticResource ForestLight}" />
    <SolidColorBrush x:Key="ResonanceNavTextBrush" Color="{StaticResource CreamWhite}" />

    <!-- Text -->
    <SolidColorBrush x:Key="ResonanceTextPrimaryBrush" Color="{StaticResource ForestDeep}" />
    <SolidColorBrush x:Key="ResonanceTextSecondaryBrush" Color="{StaticResource ForestMuted}" />
    <SolidColorBrush x:Key="ResonanceTextTertiaryBrush" Color="{StaticResource ForestSoft}" />

    <!-- Accents -->
    <SolidColorBrush x:Key="ResonanceAccentBrush" Color="{StaticResource GoldPrimary}" />
    <SolidColorBrush x:Key="ResonanceAccentLightBrush" Color="{StaticResource GoldLight}" />
    <SolidColorBrush x:Key="ResonanceAccentDarkBrush" Color="{StaticResource GoldDark}" />

    <!-- Borders -->
    <SolidColorBrush x:Key="ResonanceBorderBrush" Color="#20122E21" />
    <SolidColorBrush x:Key="ResonanceGoldBorderBrush" Color="#40C5A059" />
    <SolidColorBrush x:Key="ResonanceSubtleBorderBrush" Color="#10000000" />

    <!-- Acrylic Brushes -->
    <AcrylicBrush x:Key="ResonanceAcrylicBackgroundBrush"
                  TintColor="{StaticResource CreamWarm}"
                  TintOpacity="0.85"
                  FallbackColor="{StaticResource CreamWarm}" />

    <AcrylicBrush x:Key="ResonanceAcrylicCardBrush"
                  TintColor="#FFFFFFFF"
                  TintOpacity="0.8"
                  FallbackColor="#FFFFFFFF" />

    <AcrylicBrush x:Key="ResonanceAcrylicNavBrush"
                  TintColor="{StaticResource ForestDeep}"
                  TintOpacity="0.92"
                  FallbackColor="{StaticResource ForestDeep}" />

    <AcrylicBrush x:Key="ResonanceAcrylicDarkBrush"
                  TintColor="{StaticResource ForestNight}"
                  TintOpacity="0.88"
                  FallbackColor="{StaticResource ForestNight}" />

    <!-- Gold Gradient -->
    <LinearGradientBrush x:Key="ResonanceGoldGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource GoldDark}" Offset="0.0" />
        <GradientStop Color="{StaticResource GoldPrimary}" Offset="0.4" />
        <GradientStop Color="{StaticResource GoldLight}" Offset="0.7" />
        <GradientStop Color="{StaticResource GoldPrimary}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ResonanceForestGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ForestDeep}" Offset="0.0" />
        <GradientStop Color="{StaticResource ForestMid}" Offset="0.5" />
        <GradientStop Color="{StaticResource ForestLight}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ResonanceCosmicGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ForestNight}" Offset="0.0" />
        <GradientStop Color="{StaticResource ForestDeep}" Offset="0.5" />
        <GradientStop Color="#FF1A3528" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ══════════════════════════════════════════
         CORNER RADIUS
         ══════════════════════════════════════════ -->
    <CornerRadius x:Key="ResonanceCornerSmall">4</CornerRadius>
    <CornerRadius x:Key="ResonanceCornerMedium">8</CornerRadius>
    <CornerRadius x:Key="ResonanceCornerLarge">12</CornerRadius>
    <CornerRadius x:Key="ResonanceCornerXLarge">16</CornerRadius>
    <CornerRadius x:Key="ResonanceCornerRound">999</CornerRadius>

    <!-- ══════════════════════════════════════════
         THICKNESS / SPACING
         ══════════════════════════════════════════ -->
    <Thickness x:Key="ResonanceCardPadding">20</Thickness>
    <Thickness x:Key="ResonancePagePadding">32,24,32,24</Thickness>
    <Thickness x:Key="ResonanceItemSpacing">0,0,0,12</Thickness>
    <x:Double x:Key="ResonanceCardElevation">2</x:Double>

    <!-- ══════════════════════════════════════════
         TEXT STYLES
         ══════════════════════════════════════════ -->

    <!-- Display / Hero text - Serif -->
    <Style x:Key="ResonanceDisplayStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cambria, Georgia, Times New Roman" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="44" />
    </Style>

    <!-- Page Title - Serif -->
    <Style x:Key="ResonanceTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cambria, Georgia, Times New Roman" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Section Title - Serif -->
    <Style x:Key="ResonanceSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cambria, Georgia, Times New Roman" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Body Text - Sans-serif -->
    <Style x:Key="ResonanceBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="22" />
    </Style>

    <!-- Caption Text -->
    <Style x:Key="ResonanceCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceTextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Gold Accent Label -->
    <Style x:Key="ResonanceAccentLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceAccentBrush}" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ══════════════════════════════════════════
         CARD STYLES
         ══════════════════════════════════════════ -->

    <!-- Elevated Card -->
    <Style x:Key="ResonanceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResonanceAcrylicCardBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerLarge}" />
        <Setter Property="Padding" Value="{StaticResource ResonanceCardPadding}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceSubtleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Gold-bordered Card -->
    <Style x:Key="ResonanceGoldCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResonanceAcrylicCardBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerLarge}" />
        <Setter Property="Padding" Value="{StaticResource ResonanceCardPadding}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceGoldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- Dark Card (for hero / feature sections) -->
    <Style x:Key="ResonanceDarkCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResonanceAcrylicDarkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerLarge}" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceGoldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════
         BUTTON STYLES
         ══════════════════════════════════════════ -->

    <!-- Primary Gold Button -->
    <Style x:Key="ResonancePrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ResonanceAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceNavBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerMedium}" />
        <Setter Property="Padding" Value="24,10,24,10" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Secondary Outlined Button -->
    <Style x:Key="ResonanceSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceAccentBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerMedium}" />
        <Setter Property="Padding" Value="24,10,24,10" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceGoldBorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- ══════════════════════════════════════════
         NAVIGATION ITEM STYLE
         ══════════════════════════════════════════ -->

    <Style x:Key="ResonanceNavItemStyle" TargetType="NavigationViewItem">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ResonanceNavTextBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════
         INPUT STYLES
         ══════════════════════════════════════════ -->

    <Style x:Key="ResonanceTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="{StaticResource ResonanceCornerMedium}" />
        <Setter Property="BorderBrush" Value="{StaticResource ResonanceBorderBrush}" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <!-- ══════════════════════════════════════════
         SHADOW (simulated with Border)
         ══════════════════════════════════════════ -->
    <ThemeShadow x:Key="ResonanceCardShadow" />

</ResourceDictionary>
