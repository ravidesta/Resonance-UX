const THERAPIST_COURSES = [
  {
    title: 'Understanding RSD: A Clinical Perspective',
    type: 'Course', format: 'Audio + eBook',
    lessons: 12, duration: '6 hours',
    progress: 75, color: '#6A9BC2'
  },
  {
