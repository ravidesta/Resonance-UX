function RSDWorkbook() {
  const [darkMode, setDarkMode] = useState(false);
  const [selectedChapter, setSelectedChapter] = useState(null);
  const [selectedExercise, setSelectedExercise] = useState(null);
  const [completedExercises, setCompletedExercises] = useState(new Set());
  const [view, setView] = useState('chapters');

  const bg = darkMode ? '#05100B' : '#FAFAF8';
  const textMain = darkMode ? '#E8F0EA' : '#122E21';
  const textMuted = darkMode ? '#8A9C91' : '#5C7065';
  const glassBg = darkMode ? 'rgba(10, 28, 20, 0.85)' : 'rgba(255, 255, 255, 0.75)';
  const glassBorder = darkMode ? 'rgba(197, 160, 89, 0.12)' : 'rgba(18, 46, 33, 0.08)';
  const gold = '#C5A059';

  const totalExercises = CHAPTERS.reduce((a, c) => a + c.exercises.length, 0);

  const getTypeIcon = (type) => {
    const icons = { reflection: '🪞', writing: '✍️', checklist: '✅', game: '🎮', art: '🎨', assessment: '📊', planning: '📋', tracker: '📈', practice: '🧘', sensory: '🌿' };
    return icons[type] || '📝';
  };

  const renderChapters = () => (
    <div style={{ padding: '60px 20px 100px' }}>
      <div style={{ marginBottom: 24 }}>
        <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted, letterSpacing: '0.06em', textTransform: 'uppercase', marginBottom: 4 }}>
          INTERACTIVE MULTIMEDIA WORKBOOK
        </p>
        <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: 28, color: textMain, fontWeight: 500 }}>
          Your Exercises
        </p>
        <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMuted, marginTop: 4 }}>
          {totalExercises} exercises · 11 guided meditations · Printable PDFs
        </p>
      </div>

      {/* Progress */}
      <div style={{
        background: glassBg, backdropFilter: 'blur(16px)',
        border: `1px solid ${glassBorder}`, borderRadius: 20,
        padding: '16px 20px', marginBottom: 20
      }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 8 }}>
          <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMuted }}>Overall progress</span>
          <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: gold, fontWeight: 600 }}>
            {completedExercises.size}/{totalExercises}
          </span>
        </div>
        <div style={{ height: 6, borderRadius: 3, background: darkMode ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.04)' }}>
          <div style={{
            width: `${(completedExercises.size / totalExercises) * 100}%`,
            height: '100%', borderRadius: 3, background: gold, transition: 'width 0.5s ease'
          }} />
        </div>
      </div>

      {/* Chapter Cards */}
      {CHAPTERS.map(chapter => {
        const chapterCompleted = chapter.exercises.filter(e => completedExercises.has(`${chapter.id}-${e.title}`)).length;
        return (
          <button key={chapter.id} onClick={() => { setSelectedChapter(chapter); setView('exercises'); }} style={{
            width: '100%', background: glassBg, backdropFilter: 'blur(12px)',
            border: `1px solid ${glassBorder}`, borderRadius: 20,
            padding: '16px 18px', cursor: 'pointer', marginBottom: 10,
            textAlign: 'left', display: 'flex', gap: 14, alignItems: 'center'
          }}>
            <div style={{
              width: 50, height: 50, borderRadius: 16,
              background: `linear-gradient(135deg, ${chapter.color}, ${chapter.color}80)`,
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: 24, flexShrink: 0, boxShadow: `0 4px 12px ${chapter.color}25`
            }}>{chapter.icon}</div>
            <div style={{ flex: 1 }}>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMain, fontWeight: 600, marginBottom: 2 }}>
                Ch. {chapter.id}: {chapter.title.length > 30 ? chapter.title.slice(0, 30) + '...' : chapter.title}
              </p>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 10, color: textMuted }}>
                {chapter.exercises.length} exercises · 1 meditation · {chapterCompleted} done
              </p>
              <div style={{ display: 'flex', gap: 2, marginTop: 6 }}>
                {chapter.exercises.map((e, i) => (
                  <div key={i} style={{
                    flex: 1, height: 3, borderRadius: 2,
                    background: completedExercises.has(`${chapter.id}-${e.title}`) ? chapter.color : (darkMode ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)')
                  }} />
                ))}
              </div>
            </div>
          </button>
        );
      })}
    </div>
  );

  const renderExercises = () => {
    if (!selectedChapter) return null;
    const ch = selectedChapter;

    return (
      <div style={{ padding: '60px 20px 100px' }}>
        <button onClick={() => { setView('chapters'); setSelectedChapter(null); }} style={{
          background: 'transparent', border: 'none', cursor: 'pointer',
          display: 'flex', alignItems: 'center', gap: 6, marginBottom: 20
        }}>
          <span style={{ color: textMuted }}>‹</span>
          <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: textMuted }}>Back</span>
        </button>

        <div style={{ display: 'flex', alignItems: 'center', gap: 14, marginBottom: 24 }}>
          <div style={{
            width: 56, height: 56, borderRadius: 18,
            background: `linear-gradient(135deg, ${ch.color}, ${ch.color}80)`,
            display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 28
          }}>{ch.icon}</div>
          <div>
            <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 10, color: ch.color, fontWeight: 600 }}>CHAPTER {ch.id}</p>
            <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: 20, color: textMain, fontWeight: 500 }}>{ch.title}</p>
          </div>
        </div>

        {/* Meditation Card */}
        <div style={{
          background: `linear-gradient(135deg, ${ch.color} 0%, ${ch.color}80 100%)`,
          borderRadius: 20, padding: '18px 20px', marginBottom: 20,
          position: 'relative', overflow: 'hidden', cursor: 'pointer'
        }}>
          <div style={{
            position: 'absolute', top: -20, right: -20,
            width: 80, height: 80, borderRadius: '50%',
            background: 'rgba(255,255,255,0.1)'
          }} />
          <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 10, color: 'rgba(255,255,255,0.7)', letterSpacing: '0.04em', textTransform: 'uppercase', marginBottom: 4 }}>
            GUIDED MEDITATION
          </p>
          <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: 18, color: '#FFFFFF', fontWeight: 500, marginBottom: 2 }}>
            {ch.meditation.title}
          </p>
          <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: 'rgba(255,255,255,0.8)' }}>
            {ch.meditation.duration} · {ch.meditation.music}
          </p>
          <div style={{
            display: 'flex', alignItems: 'center', gap: 8, marginTop: 12
          }}>
            <div style={{
              width: 32, height: 32, borderRadius: '50%',
              background: 'rgba(255,255,255,0.2)',
              display: 'flex', alignItems: 'center', justifyContent: 'center'
            }}>▶</div>
            <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: 'rgba(255,255,255,0.9)' }}>Play</span>
          </div>
        </div>

        {/* Exercises */}
        {ch.exercises.map((exercise, i) => {
          const key = `${ch.id}-${exercise.title}`;
          const done = completedExercises.has(key);
          return (
            <div key={i} style={{
              background: done ? `${ch.color}08` : glassBg,
              backdropFilter: 'blur(12px)',
              border: `1px solid ${done ? `${ch.color}25` : glassBorder}`,
              borderRadius: 20, padding: '16px 18px', marginBottom: 10
            }}>
              <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                <span style={{ fontSize: 20, marginTop: 2 }}>{getTypeIcon(exercise.type)}</span>
                <div style={{ flex: 1 }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 4 }}>
                    <p style={{
                      fontFamily: "'Manrope', sans-serif", fontSize: 14, color: textMain,
                      fontWeight: 600, textDecoration: done ? 'line-through' : 'none',
                      opacity: done ? 0.6 : 1
                    }}>{exercise.title}</p>
                    <div style={{ display: 'flex', gap: 4 }}>
                      {exercise.printable && (
                        <span style={{
                          fontFamily: "'Manrope', sans-serif", fontSize: 8,
                          color: textMuted, background: darkMode ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.03)',
                          borderRadius: 6, padding: '2px 6px'
                        }}>PDF</span>
                      )}
                      {exercise.interactive && (
                        <span style={{
                          fontFamily: "'Manrope', sans-serif", fontSize: 8,
                          color: ch.color, background: `${ch.color}15`,
                          borderRadius: 6, padding: '2px 6px'
                        }}>Interactive</span>
                      )}
                    </div>
                  </div>
                  <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMuted, lineHeight: 1.5, marginBottom: 10 }}>
                    {exercise.description}
                  </p>
                  <div style={{ display: 'flex', gap: 8 }}>
                    <button style={{
                      background: ch.color, border: 'none',
                      borderRadius: 12, padding: '8px 16px', cursor: 'pointer'
                    }}>
                      <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: '#FFF', fontWeight: 600 }}>
                        {exercise.interactive ? 'Play' : 'Start'}
                      </span>
                    </button>
                    {exercise.printable && (
                      <button style={{
                        background: glassBg, border: `1px solid ${glassBorder}`,
                        borderRadius: 12, padding: '8px 14px', cursor: 'pointer'
                      }}>
                        <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted }}>🖨 Print</span>
                      </button>
                    )}
                    <button onClick={() => {
                      setCompletedExercises(prev => {
                        const next = new Set(prev);
                        if (next.has(key)) next.delete(key);
                        else next.add(key);
                        return next;
                      });
                    }} style={{
                      background: done ? `${ch.color}20` : 'transparent',
                      border: `1px solid ${done ? ch.color : glassBorder}`,
                      borderRadius: 12, padding: '8px 14px', cursor: 'pointer'
                    }}>
                      <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: done ? ch.color : textMuted }}>
                        {done ? '✓ Done' : 'Mark done'}
                      </span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    );
  };

  return (
    <div style={{
      display: 'flex', justifyContent: 'center', alignItems: 'flex-start',
      minHeight: '100vh', background: darkMode ? '#020805' : '#F0EDE8',
      padding: 20, fontFamily: "'Manrope', sans-serif"
    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        ::-webkit-scrollbar { display: none; }
      `}</style>

      <div style={{
        width: 390, minHeight: 844, background: bg,
        borderRadius: 44, overflow: 'hidden', position: 'relative',
        boxShadow: darkMode
          ? '0 25px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(197,160,89,0.08)'
          : '0 25px 80px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04)',
      }}>
        <div style={{ height: 844, overflowY: 'auto', scrollbarWidth: 'none' }}>
          {view === 'chapters' && renderChapters()}
          {view === 'exercises' && renderExercises()}
        </div>
      </div>
    </div>
  );
}

ReactDOM.render(<RSDWorkbook />, document.getElementById('root'));
