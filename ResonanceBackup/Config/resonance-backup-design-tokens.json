{
  "name": "Resonance Backup Design Tokens",
  "version": "1.0.0",
  "description": "Design tokens for the Resonance UX GitHub Backup system, combining Resonance UX + Luminous OS aesthetics",

  "colors": {
    "palette": {
      "forest": {
        "900": "#0A1C14",
        "800": "#122E21",
        "700": "#1B402E",
        "200": "#D1E0D7",
        "100": "#E8F0EA"
      },
      "gold": {
        "primary": "#C5A059",
        "light": "#E6D0A1",
        "dark": "#9A7A3A"
      },
      "bioluminescent": {
        "growth_green": "#59C9A5",
        "strategic_blue": "#7B8CDE",
        "creative_magenta": "#E040FB",
        "warmth_amber": "#F4A261",
        "signal_teal": "#4ECDC4",
        "rhythm_coral": "#EF6461"
      }
    },
    "semantic": {
      "bg_light": "#FAFAF8",
      "bg_dark": "#05100B",
      "bg_dark_surface": "#0A1C14",
      "text_main": "#122E21",
      "text_muted": "#5C7065",
      "text_light": "#8A9C91",
      "border_light": "#E5EBE7",
      "status_active": "rgba(89, 201, 165, 0.8)",
      "status_warning": "rgba(244, 162, 97, 0.8)",
      "status_error": "rgba(239, 100, 97, 0.8)",
      "status_idle": "rgba(123, 140, 222, 0.4)"
    }
  },

  "typography": {
    "families": {
      "heading": "Cormorant Garamond",
      "body": "Manrope",
      "mono": "SF Mono, system-ui monospace"
    },
    "scales": {
      "title": { "size": 28, "weight": "semibold", "family": "heading" },
      "heading": { "size": 22, "weight": "medium", "family": "heading" },
      "subheading": { "size": 18, "weight": "medium", "family": "heading" },
      "body": { "size": 14, "weight": "regular", "family": "body" },
      "caption": { "size": 12, "weight": "light", "family": "body" },
      "callsign": { "size": 11, "weight": "bold", "family": "mono", "tracking": 2 }
    }
  },

  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },

  "radii": {
    "compact": 14,
    "standard": 20,
    "large": 28
  },

  "effects": {
    "breathing_blob": {
      "duration": "16s",
      "scale_range": [1.0, 1.05],
      "blur": 60,
      "opacity_light": 0.3,
      "opacity_dark": 0.15
    },
    "living_surface": {
      "breathe_rate": 0.006,
      "bg_opacity_base": 0.03,
      "bg_opacity_range": 0.015,
      "border_opacity_base": 0.06,
      "border_opacity_range": 0.03,
      "hover_translate_y": -1,
      "hover_border_opacity": 0.14
    },
    "chromatic_orb": {
      "glow_radius_multiplier": 2.5,
      "glow_blur_multiplier": 0.8,
      "pulse_duration": "2s",
      "inner_gradient_center": [0.3, 0.3]
    },
    "indicator_light": {
      "glow_multiplier": 2.2,
      "blur_multiplier": 0.6
    },
    "glass_panel": {
      "material": "ultraThinMaterial",
      "border_opacity_dark": 0.08,
      "border_width": 0.5
    },
    "paper_noise": {
      "density": 0.003,
      "opacity": 0.035
    }
  },

  "shadows": {
    "light": {
      "glass": "0 16px 40px rgba(154, 122, 58, 0.12)",
      "card": "0 8px 24px rgba(154, 122, 58, 0.08)",
      "card_hover": "0 24px 48px rgba(154, 122, 58, 0.18)"
    },
    "dark": {
      "glass": "0 16px 40px rgba(0, 0, 0, 0.7)",
      "card": "0 8px 24px rgba(0, 0, 0, 0.5)",
      "card_hover": "0 24px 48px rgba(0, 0, 0, 0.9)"
    }
  },

  "animations": {
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "smooth": "cubic-bezier(0.165, 0.84, 0.44, 1)",
    "gently_out": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
