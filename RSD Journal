function RSDJournal() {
  const [locked, setLocked] = useState(true);
  const [passcode, setPasscode] = useState('');
  const [view, setView] = useState('entries');
  const [entries, setEntries] = useState(SAMPLE_ENTRIES);
  const [selectedEntry, setSelectedEntry] = useState(null);
  const [isWriting, setIsWriting] = useState(false);
  const [darkMode, setDarkMode] = useState(false);
  const [showPrompts, setShowPrompts] = useState(false);
  const [selectedChapter, setSelectedChapter] = useState(null);
  const [newEntry, setNewEntry] = useState({ title: '', content: '', mood: null, tags: [] });
  const [showShareDialog, setShowShareDialog] = useState(false);
  const [biometricEnabled, setBiometricEnabled] = useState(true);

  const bg = darkMode ? '#05100B' : '#FAFAF8';
  const textMain = darkMode ? '#E8F0EA' : '#122E21';
  const textMuted = darkMode ? '#8A9C91' : '#5C7065';
  const textLight = darkMode ? '#5C7065' : '#8A9C91';
  const glassBg = darkMode ? 'rgba(10, 28, 20, 0.85)' : 'rgba(255, 255, 255, 0.75)';
  const glassBorder = darkMode ? 'rgba(197, 160, 89, 0.12)' : 'rgba(18, 46, 33, 0.08)';
  const gold = '#C5A059';

  const handlePasscode = (digit) => {
    const next = passcode + digit;
    setPasscode(next);
    if (next.length >= 4) {
      setTimeout(() => {
        setLocked(false);
        setPasscode('');
      }, 300);
    }
  };

  const renderLockScreen = () => (
    <div style={{
      height: 844,
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      justifyContent: 'center',
      padding: 40
    }}>
      <div style={{
        width: 72, height: 72, borderRadius: '50%',
        background: `${gold}15`,
        display: 'flex', alignItems: 'center', justifyContent: 'center',
        marginBottom: 20
      }}>
        <span style={{ fontSize: 32 }}>🔒</span>
      </div>
      <p style={{
        fontFamily: "'Cormorant Garamond', serif",
        fontSize: 24, color: textMain, fontWeight: 500, marginBottom: 6
      }}>Your Safe Space</p>
      <p style={{
        fontFamily: "'Manrope', sans-serif",
        fontSize: 13, color: textMuted, marginBottom: 32
      }}>Enter your passcode to unlock</p>

      {/* Dots */}
      <div style={{ display: 'flex', gap: 16, marginBottom: 40 }}>
        {[0,1,2,3].map(i => (
          <div key={i} style={{
            width: 14, height: 14, borderRadius: '50%',
            background: i < passcode.length ? gold : 'transparent',
            border: `2px solid ${i < passcode.length ? gold : textLight}`,
            transition: 'all 0.2s ease'
          }} />
        ))}
      </div>

      {/* Numpad */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 16, maxWidth: 260 }}>
        {[1,2,3,4,5,6,7,8,9,'bio',0,'del'].map(key => (
          <button key={key} onClick={() => {
            if (key === 'del') setPasscode(passcode.slice(0, -1));
            else if (key === 'bio') { setLocked(false); }
            else handlePasscode(String(key));
          }} style={{
            width: 72, height: 72, borderRadius: '50%',
            background: key === 'bio' ? `${gold}15` : (darkMode ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.03)'),
            border: `1px solid ${glassBorder}`,
            cursor: 'pointer',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            transition: 'all 0.2s ease'
          }}>
            {key === 'bio' ? (
              <span style={{ fontSize: 24 }}>👆</span>
            ) : key === 'del' ? (
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMuted }}>⌫</span>
            ) : (
              <span style={{
                fontFamily: "'Cormorant Garamond', serif",
                fontSize: 28, color: textMain
              }}>{key}</span>
            )}
          </button>
        ))}
      </div>

      <p style={{
        fontFamily: "'Manrope', sans-serif",
        fontSize: 11, color: textLight, marginTop: 20
      }}>Your entries never leave this device unless you choose to share them.</p>
    </div>
  );

