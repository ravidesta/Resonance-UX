              display: 'flex', alignItems: 'center', gap: 4
            }}>
              <span style={{ fontSize: 14 }}>{m.emoji}</span>
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 10, color: textMuted }}>{m.label}</span>
            </button>
          ))}
        </div>
      </div>

      {/* Title */}
      <div style={{
        background: 'transparent', borderBottom: `1px solid ${glassBorder}`,
