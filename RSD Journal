              {selectedEntry.sharedWithTherapist ? 'Shared with therapist' : 'Share with therapist'}
            </span>
          </button>
          <button style={{
            background: glassBg, border: `1px solid ${glassBorder}`,
            borderRadius: 16, padding: '14px 18px', cursor: 'pointer'
          }}>
            <span style={{ fontSize: 16 }}>📤</span>
          </button>
        </div>
      </div>
    );
  };

  const renderWriting = () => (
    <div style={{ padding: '60px 20px 100px' }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <button onClick={() => setIsWriting(false)} style={{
          background: 'transparent', border: 'none', cursor: 'pointer'
        }}>
          <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: textMuted }}>Cancel</span>
        </button>
        <button style={{
          background: gold, border: 'none', borderRadius: 12,
          padding: '8px 20px', cursor: 'pointer'
        }}>
          <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: '#FFFFFF', fontWeight: 600 }}>Save</span>
