            <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: 15, color: textMain, fontStyle: 'italic', lineHeight: 1.5 }}>
              {selectedEntry.prompt}
            </p>
          </div>
        )}

        <p style={{
          fontFamily: "'Manrope', sans-serif", fontSize: 14,
          color: textMain, lineHeight: 1.8, marginBottom: 24
