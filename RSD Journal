          }}>
            <div>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 14, color: textMain, fontWeight: 500 }}>{chapter}</p>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted }}>
                {JOURNAL_PROMPTS[chapter].length} prompts
              </p>
            </div>
            <span style={{ color: textLight }}>›</span>
          </button>
        ))
      ) : (
        JOURNAL_PROMPTS[selectedChapter].map((prompt, i) => (
          <button key={i} onClick={() => {
            setNewEntry({ title: '', content: '', mood: null, tags: [] });
            setIsWriting(true);
            setShowPrompts(false);
            setSelectedChapter(null);
          }} style={{
            width: '100%', background: glassBg, backdropFilter: 'blur(12px)',
            border: `1px solid ${glassBorder}`, borderRadius: 20,
            padding: '18px', cursor: 'pointer', marginBottom: 10,
            textAlign: 'left'
          }}>
            <div style={{
              fontFamily: "'Manrope', sans-serif", fontSize: 10, color: gold,
              fontWeight: 600, letterSpacing: '0.04em', marginBottom: 6
            }}>PROMPT {i + 1}</div>
            <p style={{
              fontFamily: "'Cormorant Garamond', serif", fontSize: 16,
              color: textMain, lineHeight: 1.5, fontStyle: 'italic'
            }}>{prompt}</p>
            <div style={{
              marginTop: 10, display: 'flex', alignItems: 'center', gap: 6
            }}>
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: gold, fontWeight: 500 }}>
                Start writing →
              </span>
            </div>
          </button>
        ))
      )}
    </div>
  );

  return (
    <div style={{
      display: 'flex', justifyContent: 'center', alignItems: 'flex-start',
      minHeight: '100vh', background: darkMode ? '#020805' : '#F0EDE8',
      padding: 20, fontFamily: "'Manrope', sans-serif"
    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        ::-webkit-scrollbar { display: none; }
      `}</style>

      <div style={{
        width: 390, minHeight: 844, background: bg,
        borderRadius: 44, overflow: 'hidden', position: 'relative',
        boxShadow: darkMode
          ? '0 25px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(197,160,89,0.08)'
          : '0 25px 80px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04)',
      }}>
        <div style={{ height: 844, overflowY: 'auto', scrollbarWidth: 'none' }}>
          {locked && renderLockScreen()}
          {!locked && showPrompts && renderPrompts()}
          {!locked && !showPrompts && isWriting && renderWriting()}
          {!locked && !showPrompts && !isWriting && view === 'entries' && renderEntries()}
          {!locked && !showPrompts && !isWriting && view === 'read' && renderReadEntry()}
        </div>
      </div>
    </div>
  );
}

ReactDOM.render(<RSDJournal />, document.getElementById('root'));
