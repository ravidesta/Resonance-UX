        {selectedEntry.tags.length > 0 && (
          <div style={{ display: 'flex', gap: 6, marginBottom: 24, flexWrap: 'wrap' }}>
            {selectedEntry.tags.map(tag => (
              <span key={tag} style={{
                fontFamily: "'Manrope', sans-serif", fontSize: 10,
