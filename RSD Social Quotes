            width: 44, height: 24, borderRadius: 12,
            background: showBookLink ? '#7BA68C' : (darkMode ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)'),
            padding: 2, cursor: 'pointer', transition: 'all 0.3s ease'
