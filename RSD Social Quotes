        </p>
        <p style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: 28, color: textMain, fontWeight: 500 }}>
          Quote Cards
        </p>
        <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMuted, marginTop: 4 }}>
          Beautiful shareable quotes optimized for every platform
        </p>
      </div>

      {/* Platform selector */}
      <div style={{ display: 'flex', gap: 6, marginBottom: 20, overflowX: 'auto', scrollbarWidth: 'none' }}>
        {PLATFORMS.map(p => (
          <button key={p.id} onClick={() => setSelectedPlatform(p.id)} style={{
            background: selectedPlatform === p.id ? `${gold}20` : glassBg,
            border: `1px solid ${selectedPlatform === p.id ? `${gold}40` : glassBorder}`,
            borderRadius: 14, padding: '8px 12px', cursor: 'pointer',
            display: 'flex', alignItems: 'center', gap: 6, whiteSpace: 'nowrap'
          }}>
            <span style={{ fontSize: 14 }}>{p.icon}</span>
            <div style={{ textAlign: 'left' }}>
              <span style={{
                fontFamily: "'Manrope', sans-serif", fontSize: 10,
                color: selectedPlatform === p.id ? gold : textMuted,
                fontWeight: selectedPlatform === p.id ? 600 : 400,
                display: 'block'
              }}>{p.name}</span>
              <span style={{
                fontFamily: "'Manrope', sans-serif", fontSize: 8, color: textLight
              }}>{p.size}</span>
            </div>
          </button>
        ))}
      </div>

      {/* Preview */}
      <div style={{ marginBottom: 20 }}>
        {renderQuoteCard()}
