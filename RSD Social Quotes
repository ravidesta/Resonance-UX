      <div style={{ display: 'flex', gap: 4, flexWrap: 'wrap', marginBottom: 16 }}>
        {quote.tags.map(tag => (
          <span key={tag} style={{
            fontFamily: "'Manrope', sans-serif", fontSize: 10,
            color: gold, background: `${gold}10`,
            borderRadius: 8, padding: '3px 8px'
          }}>{tag}</span>
        ))}
      </div>

      {/* Share buttons */}
      <div style={{ display: 'flex', gap: 8, marginBottom: 24 }}>
        <button style={{
          flex: 1, background: gold, border: 'none',
          borderRadius: 16, padding: '14px', cursor: 'pointer'
