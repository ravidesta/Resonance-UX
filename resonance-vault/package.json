{
  "name": "resonance-vault",
  "version": "1.0.0",
  "description": "Resonance Vault — GitHub Backup & Portfolio System with Luminous UX",
  "main": "src/server/index.js",
  "bin": {
    "resonance-vault": "./src/cli/index.js"
  },
  "scripts": {
    "dev": "react-scripts start",
    "build": "react-scripts build",
