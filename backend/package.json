{
  "name": "resonance-ux-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Resonance UX Backend — API server, WebSocket sync, and AI services",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.21.1",
    "ws": "^8.18.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.13",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "prisma": "^6.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
