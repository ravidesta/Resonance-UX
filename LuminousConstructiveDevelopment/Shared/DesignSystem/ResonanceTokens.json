{
  "meta": {
    "name": "Resonance-UX Design Tokens — Luminous Constructive Development™",
    "version": "1.0.0",
    "description": "Unified design tokens shared across iOS, Android, macOS, watchOS, and Web"
  },
  "color": {
    "forest": {
      "deepest": "#0A1C14",
      "deep": "#122E21",
      "base": "#1B402E",
      "muted": "#2A5A42",
      "light": "#3A7A5A"
    },
    "gold": {
      "primary": "#C5A059",
      "muted": "#9A7A3A",
      "light": "#D4B878",
      "glow": "rgba(197, 160, 89, 0.15)"
    },
    "earth": {
      "cream": "#FAFAF8",
      "warm": "#F5F0E8",
      "sand": "#E8DFD0",
      "stone": "#D4C9B8"
    },
    "text": {
      "primary": "#1B402E",
      "secondary": "#8A9C91",
      "muted": "#A8B5AD",
      "onDark": "#FAFAF8",
      "gold": "#C5A059"
    },
    "semantic": {
      "growth": "#4A9A6A",
      "awareness": "#C5A059",
      "somatic": "#8B6BB0",
      "relational": "#5A8AB0",
      "integration": "#B07A5A"
    },
    "glass": {
      "light": "rgba(250, 250, 248, 0.72)",
      "dark": "rgba(10, 28, 20, 0.85)",
      "frost": "rgba(255, 255, 255, 0.08)",
      "border": "rgba(197, 160, 89, 0.12)"
    },
    "deepRest": {
      "background": "#050E09",
      "surface": "#0A1C14",
      "card": "rgba(18, 46, 33, 0.6)",
      "text": "#C8D4CC",
      "accent": "#9A7A3A"
    }
  },
  "typography": {
    "families": {
      "serif": "Cormorant Garamond",
      "sans": "Manrope",
      "mono": "JetBrains Mono"
    },
    "scale": {
      "display": { "size": 48, "lineHeight": 1.1, "weight": 300, "family": "serif" },
      "h1": { "size": 36, "lineHeight": 1.2, "weight": 400, "family": "serif" },
      "h2": { "size": 28, "lineHeight": 1.25, "weight": 400, "family": "serif" },
      "h3": { "size": 22, "lineHeight": 1.3, "weight": 500, "family": "serif" },
      "body": { "size": 17, "lineHeight": 1.6, "weight": 400, "family": "sans" },
      "bodySmall": { "size": 15, "lineHeight": 1.5, "weight": 400, "family": "sans" },
      "caption": { "size": 13, "lineHeight": 1.4, "weight": 400, "family": "sans" },
      "label": { "size": 11, "lineHeight": 1.3, "weight": 600, "family": "sans", "letterSpacing": 0.5 }
    }
  },
  "spacing": {
    "xxs": 4,
    "xs": 8,
    "sm": 12,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "xxxl": 64
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "pill": 9999
  },
  "shadow": {
    "card": { "x": 0, "y": 4, "blur": 8, "spread": 0, "color": "rgba(10, 28, 20, 0.08)" },
    "raised": { "x": 0, "y": 8, "blur": 16, "spread": 0, "color": "rgba(10, 28, 20, 0.12)" },
    "glow": { "x": 0, "y": 0, "blur": 24, "spread": 4, "color": "rgba(197, 160, 89, 0.15)" },
    "deep": { "x": 0, "y": 16, "blur": 48, "spread": 0, "color": "rgba(10, 28, 20, 0.16)" }
  },
  "animation": {
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "breathe": { "duration": 18000, "easing": "ease-in-out" },
    "transition": {
      "fast": 150,
      "normal": 300,
      "slow": 500,
      "glacial": 800
    }
  },
  "glass": {
    "blur": { "light": 12, "heavy": 24 },
    "opacity": { "light": 0.72, "dark": 0.85 },
    "paperTexture": { "opacity": 0.035, "frequency": 0.65 }
  },
  "developmentalOrders": {
    "first":  { "name": "Impulsive Mind",        "color": "#E8A87C", "icon": "seedling" },
    "second": { "name": "Imperial Mind",          "color": "#D4956B", "icon": "flame" },
    "third":  { "name": "Socialized Mind",        "color": "#5A8AB0", "icon": "people" },
    "fourth": { "name": "Self-Authoring Mind",    "color": "#4A9A6A", "icon": "compass" },
    "fifth":  { "name": "Self-Transforming Mind",  "color": "#8B6BB0", "icon": "spiral" }
  },
  "somaticSeasons": {
    "compression": { "color": "#8A5A4A", "icon": "arrow.down.to.line" },
    "trembling":   { "color": "#B07A5A", "icon": "waveform" },
    "emptiness":   { "color": "#A8B5AD", "icon": "circle.dashed" },
    "emergence":   { "color": "#4A9A6A", "icon": "leaf" },
    "integration": { "color": "#C5A059", "icon": "infinity" }
  }
}
