// --- ADAPTIVE DEVICE INTERACTIVE CARD ---
// Reads the context to determine if it should use 3D Parallax (Desktop) 
// or Tap-Responsive Illumination (iPad/Mobile).
function InteractiveCard({ children, className, device }) {
  const [rotation, setRotation] = useState({ x: 0, y: 0 });
  const [glow, setGlow] = useState({ x: 50, y: 50, opacity: 0 });
  const [isPressed, setIsPressed] = useState(false);
  const cardRef = useRef(null);

  // Apply constraints based on device holarchy specs
  const isTouchDevice = device === 'ipad' || device === 'mobile';
  const rotationLimit = isTouchDevice ? 2 : 8;    // 75% Flatter on iPad
  const maxGlowOpacity = isTouchDevice ? 0.25 : 1; // 75% Less Light on iPad

  const handleMouseMove = (e) => {
    if (isTouchDevice || !cardRef.current) return; // Disable hover tracking on touch
    const rect = cardRef.current.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    const rotateX = ((y - centerY) / centerY) * -rotationLimit;
    const rotateY = ((x - centerX) / centerX) * rotationLimit;

    setRotation({ x: rotateX, y: rotateY });
    setGlow({ x: (x / rect.width) * 100, y: (y / rect.height) * 100, opacity: maxGlowOpacity });
  };

  const handleMouseLeave = () => {
    if (isTouchDevice) return;
    setRotation({ x: 0, y: 0 });
    setGlow({ ...glow, opacity: 0 });
  };

  // Touch-Responsive Illumination (Tap-to-Rise & Light)
  const handleTouchStart = (e) => {
    if (!isTouchDevice || !cardRef.current) return;
    const rect = cardRef.current.getBoundingClientRect();
    const touch = e.touches[0];
    const x = touch.clientX - rect.left;
    const y = touch.clientY - rect.top;
    
    setIsPressed(true);
    setGlow({ x: (x / rect.width) * 100, y: (y / rect.height) * 100, opacity: maxGlowOpacity });
  };

  const handleTouchEnd = () => {
    if (!isTouchDevice) return;
    setIsPressed(false);
    // Slowly fade the tap glow
    setTimeout(() => setGlow({ ...glow, opacity: 0 }), 300);
  };

  return (
    <div 
      ref={cardRef}
      className={`glass-card relative transition-all duration-500 ease-out ${className}`}
      style={{ 
        transform: `perspective(1200px) rotateX(${rotation.x}deg) rotateY(${rotation.y}deg) scale(${isPressed ? 0.98 : glow.opacity && !isTouchDevice ? 1.02 : 1})`, 
        transformStyle: 'preserve-3d', 
        zIndex: glow.opacity ? 20 : 1,
        borderColor: glow.opacity ? 'var(--border-focus)' : 'var(--border-light)',
        boxShadow: isPressed ? 'inset 0 4px 10px rgba(0,0,0,0.05)' : glow.opacity ? 'var(--shadow-card-hover)' : 'var(--shadow-card)'
      }}
      onMouseMove={handleMouseMove}
      onMouseLeave={handleMouseLeave}
      onTouchStart={handleTouchStart}
      onTouchEnd={handleTouchEnd}
      onTouchCancel={handleTouchEnd}
      onMouseDown={isTouchDevice ? handleTouchStart : undefined} // Simulate touch on desktop for testing
      onMouseUp={isTouchDevice ? handleTouchEnd : undefined}
    >
      {/* Reactive Bioluminescent Glow Layer */}
      <div 
        className="absolute inset-0 rounded-[inherit] pointer-events-none transition-opacity duration-300" 
        style={{ 
          opacity: glow.opacity, 
          background: `radial-gradient(circle at ${glow.x}% ${glow.y}%, rgba(197, 160, 89, ${isTouchDevice ? '0.3' : '0.15'}), transparent ${isTouchDevice ? '40%' : '60%'})` 
        }} 
      />
      {/* Content wrapper to preserve 3D stacking */}
      <div style={{ transform: isTouchDevice ? 'none' : 'translateZ(10px)' }} className="h-full w-full flex flex-col">
        {children}
      </div>
    </div>
  );
}

// --- GEMINI API HELPER ---
const callGemini = async (prompt) => {
  const apiKey = ""; 
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
  const payload = { contents: [{ parts: [{ text: prompt }] }] };
  
  let retries = 5;
  let delay = 1000;
  
  while (retries > 0) {
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error('API Error');
      const data = await res.json();
      return data.candidates?.[0]?.content?.parts?.[0]?.text || "Translation unavailable.";
    } catch (e) {
      retries--;
      if (retries === 0) return "Failed to connect to Intelligence Engine. Please try again.";
      await new Promise(r => setTimeout(r, delay));
      delay *= 2;
    }
  }
};

