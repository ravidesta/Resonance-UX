            </div>
          ))}
        </div>

        {/* Animation style */}
        <div style={{ marginBottom: 24 }}>
          <p style={{
            fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted,
            letterSpacing: '0.04em', textTransform: 'uppercase', marginBottom: 12
          }}>ANIMATION STYLE</p>
          <div style={{ display: 'flex', gap: 10 }}>
            {['circle', 'wave', 'petals', 'particles'].map(style => (
              <button key={style} onClick={() => setShowAnimation(style)} style={{
                flex: 1,
                background: showAnimation === style ? tech.color + '20' : glassBg,
                border: `1px solid ${showAnimation === style ? tech.color + '50' : glassBorder}`,
                borderRadius: 14,
                padding: '12px 8px',
