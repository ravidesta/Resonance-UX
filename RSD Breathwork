        </button>

        <div style={{
          width: 80, height: 80, borderRadius: 24,
          background: tech.gradient,
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          fontSize: 40,
          boxShadow: `0 8px 32px ${tech.color}40`,
          margin: '0 auto 20px'
        }}>{tech.icon}</div>

        <div style={{ textAlign: 'center', marginBottom: 28 }}>
          <p style={{
            fontFamily: "'Cormorant Garamond', serif",
            fontSize: 28, color: textMain, fontWeight: 500, marginBottom: 4
          }}>{tech.name}</p>
          <p style={{
            fontFamily: "'Manrope', sans-serif",
            fontSize: 14, color: tech.color, fontWeight: 500, marginBottom: 8
          }}>{tech.subtitle}</p>
          <p style={{
            fontFamily: "'Manrope', sans-serif",
            fontSize: 13, color: textMuted, lineHeight: 1.6, maxWidth: 300, margin: '0 auto'
          }}>{tech.description}</p>
        </div>

        {/* Pattern visualization */}
        <div style={{
          background: glassBg,
          backdropFilter: 'blur(16px)',
          border: `1px solid ${glassBorder}`,
          borderRadius: 24,
          padding: '20px',
          marginBottom: 20
        }}>
          <p style={{
            fontFamily: "'Manrope', sans-serif",
            fontSize: 11, color: textMuted, letterSpacing: '0.04em',
            textTransform: 'uppercase', marginBottom: 14
          }}>BREATH PATTERN</p>
          <div style={{ display: 'flex', gap: 8, justifyContent: 'center' }}>
            {[
              { label: 'In', value: tech.inhale, color: tech.color },
              ...(tech.hold > 0 ? [{ label: 'Hold', value: tech.hold, color: tech.color + '80' }] : []),
              { label: 'Out', value: tech.exhale, color: tech.color + '60' },
              ...(tech.holdOut > 0 ? [{ label: 'Rest', value: tech.holdOut, color: tech.color + '40' }] : []),
            ].map((p, i) => (
              <div key={i} style={{ textAlign: 'center' }}>
                <div style={{
                  width: 56, height: 56, borderRadius: 18,
                  background: p.color + '20',
                  border: `2px solid ${p.color}`,
                  display: 'flex', alignItems: 'center', justifyContent: 'center',
                  marginBottom: 6
                }}>
                  <span style={{
                    fontFamily: "'Cormorant Garamond', serif",
                    fontSize: 24, color: tech.color, fontWeight: 600
                  }}>{p.value}</span>
                </div>
                <span style={{
                  fontFamily: "'Manrope', sans-serif",
                  fontSize: 10, color: textMuted
                }}>{p.label}</span>
              </div>
            ))}
          </div>
          <div style={{
            marginTop: 14, display: 'flex', justifyContent: 'center', gap: 20
          }}>
            <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted }}>
              {tech.rounds} rounds
            </span>
            <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted }}>
              ~{Math.ceil((tech.inhale + tech.hold + tech.exhale + tech.holdOut) * tech.rounds / 60)} min
            </span>
          </div>
        </div>

        {/* Polyvagal info */}
        <div style={{
          background: glassBg,
          backdropFilter: 'blur(16px)',
          border: `1px solid ${glassBorder}`,
          borderRadius: 20,
          padding: '16px 20px',
          marginBottom: 24,
          display: 'flex', alignItems: 'center', gap: 12
        }}>
          <span style={{ fontSize: 20 }}>🧠</span>
          <div>
            <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 11, color: textMuted, letterSpacing: '0.03em' }}>
              POLYVAGAL EFFECT
            </p>
            <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMain, fontWeight: 500 }}>
              {tech.polyvagal}
            </p>
          </div>
        </div>

        {/* Settings */}
        <div style={{
          background: glassBg, backdropFilter: 'blur(16px)',
          border: `1px solid ${glassBorder}`, borderRadius: 20,
          padding: '16px 20px', marginBottom: 24
        }}>
          {[
            { label: 'Background Music', value: musicPlaying, toggle: () => setMusicPlaying(!musicPlaying) },
            { label: 'Watch Haptics', value: hapticFeedback, toggle: () => setHapticFeedback(!hapticFeedback) },
          ].map((setting, i) => (
            <div key={i} style={{
              display: 'flex', justifyContent: 'space-between', alignItems: 'center',
              padding: '8px 0',
              borderBottom: i === 0 ? `1px solid ${glassBorder}` : 'none'
            }}>
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: textMain }}>{setting.label}</span>
              <div onClick={setting.toggle} style={{
                width: 44, height: 24, borderRadius: 12,
                background: setting.value ? '#7BA68C' : (darkMode ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)'),
                padding: 2, cursor: 'pointer', transition: 'all 0.3s ease'
              }}>
                <div style={{
                  width: 20, height: 20, borderRadius: 10, background: '#FFFFFF',
