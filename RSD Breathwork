function RSDBreathwork() {
  const [view, setView] = useState('menu');
  const [selectedTechnique, setSelectedTechnique] = useState(null);
  const [isBreathing, setIsBreathing] = useState(false);
  const [phase, setPhase] = useState('ready');
  const [phaseTime, setPhaseTime] = useState(0);
  const [currentRound, setCurrentRound] = useState(0);
  const [totalBreaths, setTotalBreaths] = useState(0);
  const [darkMode, setDarkMode] = useState(true);
  const [showAnimation, setShowAnimation] = useState('circle');
  const [watchSync, setWatchSync] = useState(true);
  const [favoriteQuote, setFavoriteQuote] = useState(0);
  const [completed, setCompleted] = useState(false);
  const [hapticFeedback, setHapticFeedback] = useState(true);
  const [musicPlaying, setMusicPlaying] = useState(true);
  const [sessionHistory, setSessionHistory] = useState([
    { date: 'Today', technique: 'Calm the Storm', duration: '4:30', mood: 'better' },
    { date: 'Yesterday', technique: 'Box Breathing', duration: '6:00', mood: 'calm' },
    { date: 'Mar 19', technique: 'Self-Compassion', duration: '5:15', mood: 'peaceful' },
  ]);

  const animFrame = useRef(null);
  const timerRef = useRef(null);
  const startTimeRef = useRef(null);

  const bg = darkMode ? '#05100B' : '#FAFAF8';
  const surface = darkMode ? '#0A1C14' : '#FFFFFF';
  const textMain = darkMode ? '#E8F0EA' : '#122E21';
  const textMuted = darkMode ? '#8A9C91' : '#5C7065';
  const glassBg = darkMode ? 'rgba(10, 28, 20, 0.85)' : 'rgba(255, 255, 255, 0.75)';
  const glassBorder = darkMode ? 'rgba(197, 160, 89, 0.12)' : 'rgba(18, 46, 33, 0.08)';
  const gold = '#C5A059';

  // Animation state
  const [animProgress, setAnimProgress] = useState(0);

  useEffect(() => {
    const interval = setInterval(() => {
      setAnimProgress(prev => (prev + 1) % 360);
    }, 40);
    return () => clearInterval(interval);
  }, []);

  useEffect(() => {
    if (!isBreathing || !selectedTechnique) return;

    const t = selectedTechnique;
    const phases = [];
    if (t.inhale > 0) phases.push({ name: 'inhale', duration: t.inhale, label: 'Breathe In' });
    if (t.hold > 0) phases.push({ name: 'hold', duration: t.hold, label: 'Hold' });
    if (t.exhale > 0) phases.push({ name: 'exhale', duration: t.exhale, label: 'Breathe Out' });
    if (t.holdOut > 0) phases.push({ name: 'holdOut', duration: t.holdOut, label: 'Rest' });

    let phaseIdx = 0;
    let secondsInPhase = 0;
    let round = 1;

    setPhase(phases[0].name);
    setPhaseTime(phases[0].duration);
    setCurrentRound(1);

    const interval = setInterval(() => {
      secondsInPhase++;
      const currentPhase = phases[phaseIdx];

      if (secondsInPhase >= currentPhase.duration) {
        secondsInPhase = 0;
        phaseIdx++;

        if (phaseIdx >= phases.length) {
          phaseIdx = 0;
          round++;
          setTotalBreaths(prev => prev + 1);

          if (round > t.rounds) {
            setIsBreathing(false);
            setCompleted(true);
            setPhase('complete');
            clearInterval(interval);
            return;
          }
          setCurrentRound(round);
        }

        setPhase(phases[phaseIdx].name);
        setPhaseTime(phases[phaseIdx].duration - secondsInPhase);
      } else {
        setPhaseTime(phases[phaseIdx].duration - secondsInPhase);
      }
    }, 1000);

    return () => clearInterval(interval);
  }, [isBreathing, selectedTechnique]);

  const getBreathScale = () => {
    if (!isBreathing) {
      return 1 + Math.sin(animProgress * 0.017) * 0.05;
    }
    switch (phase) {
      case 'inhale': return 1.4;
      case 'hold': return 1.4;
      case 'exhale': return 0.7;
      case 'holdOut': return 0.7;
      default: return 1;
    }
  };

  const getPhaseLabel = () => {
    switch (phase) {
      case 'inhale': return 'Breathe In';
      case 'hold': return 'Hold';
      case 'exhale': return 'Breathe Out';
      case 'holdOut': return 'Rest';
      case 'complete': return 'Complete';
      default: return 'Ready';
    }
  };

  const getPhaseColor = () => {
    if (!selectedTechnique) return gold;
    return selectedTechnique.color;
  };

  const renderMenu = () => (
    <div style={{ padding: '60px 20px 100px' }}>
      <div style={{ marginBottom: 24 }}>
        <p style={{
          fontFamily: "'Manrope', sans-serif",
          fontSize: 11,
          color: textMuted,
          letterSpacing: '0.06em',
          textTransform: 'uppercase',
          marginBottom: 4
        }}>BREATHWORK FOR RSD & ADHD</p>
        <p style={{
          fontFamily: "'Cormorant Garamond', serif",
          fontSize: 28,
          color: textMain,
          fontWeight: 500
        }}>Find Your Calm</p>
      </div>

      {/* Quick SOS Button */}
      <button onClick={() => {
