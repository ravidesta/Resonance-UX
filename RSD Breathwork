            {['Calm', 'Better', 'Peaceful', 'Grounded', 'Still processing'].map(feel => (
              <button key={feel} style={{
                background: glassBg, backdropFilter: 'blur(12px)',
                border: `1px solid ${glassBorder}`, borderRadius: 14,
                padding: '8px 16px', cursor: 'pointer'
              }}>
                <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 12, color: textMain }}>{feel}</span>
              </button>
            ))}
          </div>

          <div style={{ display: 'flex', gap: 12, width: '100%' }}>
            <button onClick={() => { setView('menu'); setCompleted(false); }} style={{
              flex: 1, background: glassBg, border: `1px solid ${glassBorder}`,
              borderRadius: 16, padding: '14px', cursor: 'pointer'
            }}>
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: textMain }}>Done</span>
            </button>
            <button onClick={() => {
              setIsBreathing(true); setCompleted(false);
              setCurrentRound(0); setTotalBreaths(0);
            }} style={{
              flex: 1, background: tech.gradient, border: 'none',
              borderRadius: 16, padding: '14px', cursor: 'pointer'
            }}>
              <span style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: '#FFFFFF', fontWeight: 600 }}>Again</span>
            </button>
          </div>
        </div>
      );
    }

    return (
      <div style={{
        height: 844,
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'center',
        justifyContent: 'center',
        position: 'relative',
        overflow: 'hidden'
      }}>
        {/* Ambient background */}
        <div style={{
          position: 'absolute', inset: 0,
          background: `radial-gradient(circle at 50% 50%, ${color}15, transparent 70%)`,
          transition: 'all 2s ease'
        }} />

        {/* Back button */}
        <button onClick={() => { setIsBreathing(false); setView('menu'); }} style={{
          position: 'absolute', top: 60, left: 20,
          background: 'rgba(255,255,255,0.08)', border: 'none',
          borderRadius: 14, padding: '10px 16px', cursor: 'pointer',
          display: 'flex', alignItems: 'center', gap: 6
        }}>
          <span style={{ color: textMuted }}>✕</span>
        </button>

        {/* Round indicator */}
        <div style={{
          position: 'absolute', top: 60, right: 20,
          textAlign: 'right'
        }}>
          <p style={{
            fontFamily: "'Manrope', sans-serif", fontSize: 11,
            color: textMuted, letterSpacing: '0.04em'
          }}>Round {currentRound}/{tech.rounds}</p>
        </div>

        {/* Main breathing animation */}
        <div style={{
          position: 'relative',
          width: 240, height: 240,
          display: 'flex', alignItems: 'center', justifyContent: 'center'
        }}>
          {/* Outer ring */}
          <div style={{
            position: 'absolute',
            width: 240, height: 240,
            borderRadius: '50%',
            border: `2px solid ${color}20`,
            transform: `scale(${scale})`,
            transition: `transform ${phase === 'inhale' ? tech.inhale : phase === 'exhale' ? tech.exhale : 1}s ease-in-out`
          }} />

          {/* Main circle */}
          <div style={{
            width: 180, height: 180,
            borderRadius: '50%',
            background: `radial-gradient(circle, ${color}40, ${color}10)`,
            boxShadow: `0 0 60px ${color}30, 0 0 120px ${color}10`,
            transform: `scale(${scale})`,
            transition: `transform ${phase === 'inhale' ? tech.inhale : phase === 'exhale' ? tech.exhale : 1}s ease-in-out`,
            display: 'flex',
            flexDirection: 'column',
            alignItems: 'center',
            justifyContent: 'center'
          }}>
            <p style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: 20,
              color: textMain,
              fontWeight: 500,
              marginBottom: 4
            }}>{getPhaseLabel()}</p>
            <p style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: 40,
              color: color,
              fontWeight: 600
            }}>{phaseTime}</p>
          </div>

          {/* Particle ring */}
          {showAnimation === 'particles' && [...Array(12)].map((_, i) => {
            const angle = (i / 12) * Math.PI * 2 + animProgress * 0.01;
            const radius = 105 * scale;
            return (
              <div key={i} style={{
                position: 'absolute',
                width: 6, height: 6, borderRadius: '50%',
                background: color,
                opacity: 0.4 + Math.sin(animProgress * 0.03 + i) * 0.3,
                left: `calc(50% + ${Math.cos(angle) * radius}px - 3px)`,
                top: `calc(50% + ${Math.sin(angle) * radius}px - 3px)`,
                transition: 'all 0.5s ease'
              }} />
            );
          })}
        </div>

        {/* Phase instruction */}
        <p style={{
          fontFamily: "'Manrope', sans-serif",
          fontSize: 13,
          color: textMuted,
          marginTop: 40,
          textAlign: 'center',
          maxWidth: 260
        }}>
          {phase === 'inhale' && 'Fill your lungs slowly and gently'}
          {phase === 'hold' && 'Hold softly, no tension'}
          {phase === 'exhale' && 'Release everything that doesn\'t serve you'}
          {phase === 'holdOut' && 'Rest in the stillness'}
        </p>

        {/* Pause button */}
        <button onClick={() => setIsBreathing(!isBreathing)} style={{
          position: 'absolute', bottom: 100,
          background: 'rgba(255,255,255,0.08)',
          border: `1px solid ${glassBorder}`,
          borderRadius: 20,
          padding: '14px 32px',
          cursor: 'pointer'
        }}>
          <span style={{
            fontFamily: "'Manrope', sans-serif",
            fontSize: 14, color: textMain, fontWeight: 500
          }}>{isBreathing ? 'Pause' : 'Resume'}</span>
        </button>
      </div>
    );
  };

  return (
    <div style={{
      display: 'flex', justifyContent: 'center', alignItems: 'flex-start',
      minHeight: '100vh', background: darkMode ? '#020805' : '#F0EDE8',
      padding: 20, fontFamily: "'Manrope', sans-serif"
    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Manrope:wght@300;400;500;600;700&display=swap');
        * { margin: 0; padding: 0; box-sizing: border-box; }
        ::-webkit-scrollbar { display: none; }
        @keyframes breathe-fast { 0%, 100% { transform: scale(1); opacity: 0.2; } 50% { transform: scale(1.2); opacity: 0.4; } }
      `}</style>

      <div style={{
        width: 390, minHeight: 844, background: bg,
        borderRadius: 44, overflow: 'hidden', position: 'relative',
        boxShadow: darkMode
          ? '0 25px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(197,160,89,0.08)'
          : '0 25px 80px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04)',
      }}>
        <div style={{ height: 844, overflowY: 'auto', scrollbarWidth: 'none' }}>
          {view === 'menu' && renderMenu()}
          {view === 'preview' && renderPreview()}
          {view === 'session' && renderSession()}
        </div>
      </div>
    </div>
  );
}

ReactDOM.render(<RSDBreathwork />, document.getElementById('root'));
