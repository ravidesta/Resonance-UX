            <div>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 13, color: textMain, fontWeight: 500 }}>
                {session.technique}
              </p>
              <p style={{ fontFamily: "'Manrope', sans-serif", fontSize: 10, color: textMuted }}>
