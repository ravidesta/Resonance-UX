            <p style={{
              fontFamily: "'Manrope', sans-serif",
              fontSize: 10,
              color: textMuted,
            }}>{tech.inhale}-{tech.hold}-{tech.exhale}{tech.holdOut > 0 ? `-${tech.holdOut}` : ''} pattern  ·  {tech.rounds} rounds</p>
          </div>
          <div style={{ color: textMuted, fontSize: 18 }}>›</div>
        </button>
      ))}

      {/* Session History */}
      <div style={{ marginTop: 24 }}>
        <p style={{
          fontFamily: "'Cormorant Garamond', serif",
          fontSize: 20,
          color: textMain,
          fontWeight: 500,
          marginBottom: 14
        }}>Recent Sessions</p>
        {sessionHistory.map((session, i) => (
          <div key={i} style={{
            background: glassBg,
            backdropFilter: 'blur(12px)',
            border: `1px solid ${glassBorder}`,
            borderRadius: 16,
            padding: '12px 16px',
